<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= pet.description || '' %>">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
    <%- include('partials/header') %>

        <main class="pet-detail-page">
            <div class="container">
                <a href="/adopt" class="back-link">← Quay lại danh sách</a>

                <div class="pet-detail-grid">
                    <!-- Pet Image -->
                    <div class="pet-image-section">
                        <% 
                            // Determine main image: avatar from pet_images or fallback to image_url 
                            const mainImage = (typeof images !== 'undefined' && images.length > 0)
                                ? images[0].image_path
                                : (pet.avatar_image || pet.image_url || 'https://via.placeholder.com/600x400?text=No+Image');
                            const galleryImages = (typeof images !== 'undefined' && images.length > 0)
                                ? images
                                : [];
                        %>
                            <img src="<%= mainImage %>" alt="<%= pet.name %>" class="pet-main-image" id="mainImage"
                                data-pet-id="<%= pet.id %>" onerror="fallbackPetImage(this, this.dataset.petId)">
                            <div class="pet-status-badge <%= pet.status %>">
                                <%= pet.status==='available' ? '🟢 Sẵn sàng nhận nuôi' : pet.status==='pending'
                                    ? '🟡 Đang xử lý' : '🔴 Đã được nhận nuôi' %>
                            </div>

                            <% if (galleryImages.length > 1) { 
                                const previewGalleryImages = galleryImages.slice(0, 5);
                                const extraGalleryImages = galleryImages.slice(5);
                            %>
                                <div class="pet-gallery">
                                    <% previewGalleryImages.forEach(function(img, index) { %>
                                        <div class="gallery-thumb <%= index === 0 ? 'active' : '' %>"
                                            data-image-path="<%= img.image_path %>"
                                            onclick="changeMainImage(this.dataset.imagePath, this)">
                                            <img src="<%= img.image_path %>"
                                                alt="<%= pet.name %> - Ảnh <%= index + 1 %>"
                                                data-pet-id="<%= pet.id %>"
                                                onerror="fallbackPetImage(this, this.dataset.petId)">
                                        </div>
                                        <% }); %>
                                </div>

                                <% if (extraGalleryImages.length > 0) { %>
                                    <details class="pet-gallery-dropdown">
                                        <summary>Xem thêm <%= extraGalleryImages.length %> ảnh</summary>
                                        <div class="pet-gallery pet-gallery-extra">
                                            <% extraGalleryImages.forEach(function(img, index) { %>
                                                <div class="gallery-thumb" data-image-path="<%= img.image_path %>"
                                                    onclick="changeMainImage(this.dataset.imagePath, this)">
                                                    <img src="<%= img.image_path %>"
                                                        alt="<%= pet.name %> - Ảnh <%= index + previewGalleryImages.length + 1 %>"
                                                        data-pet-id="<%= pet.id %>"
                                                        onerror="fallbackPetImage(this, this.dataset.petId)">
                                                </div>
                                            <% }); %>
                                        </div>
                                    </details>
                                <% } %>
                                <% } %>
                    </div>

                    <!-- Pet Info -->
                    <div class="pet-info-section">
                        <span class="pet-species-tag">
                            <%= pet.pet_type==='Chó' ? '🐕 Chó' : pet.pet_type==='Mèo' ? '🐱 Mèo' : '🐰 ' +
                                (pet.pet_type || 'Khác' ) %>
                        </span>

                        <h1 class="pet-name">
                            <%= pet.name %>
                        </h1>

                        <% if (pet.pet_code) { %>
                            <p style="color: #2d6a4f; font-weight: 600; margin-bottom: 15px;">Mã HPA: <%= pet.pet_code
                                    %>
                            </p>
                            <% } %>

                                <p class="pet-description">
                                    <%= pet.description || '' %>
                                </p>

                                <div class="pet-details-grid">
                                    <% if (pet.breed) { %>
                                        <div class="detail-item">
                                            <span class="detail-icon">🐾</span>
                                            <div>
                                                <span class="detail-label">Giống</span>
                                                <span class="detail-value">
                                                    <%= pet.breed %>
                                                </span>
                                            </div>
                                        </div>
                                        <% } %>

                                            <% if (pet.age) { %>
                                                <div class="detail-item">
                                                    <span class="detail-icon">🎂</span>
                                                    <div>
                                                        <span class="detail-label">Tuổi</span>
                                                        <span class="detail-value">
                                                            <%= pet.age %>
                                                        </span>
                                                    </div>
                                                </div>
                                                <% } %>

                                                    <% if (pet.gender) { %>
                                                        <div class="detail-item">
                                                            <span class="detail-icon">
                                                                <%= pet.gender==='Đực' ? '♂️' : '♀️' %>
                                                            </span>
                                                            <div>
                                                                <span class="detail-label">Giới tính</span>
                                                                <span class="detail-value">
                                                                    <%= pet.gender %>
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <% } %>

                                                            <% if (pet.weight) { %>
                                                                <div class="detail-item">
                                                                    <span class="detail-icon">kg</span>
                                                                    <div>
                                                                        <span class="detail-label">Cân nặng</span>
                                                                        <span class="detail-value">
                                                                            <%= pet.weight %>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                <% } %>

                                                                    <% if (pet.color) { %>
                                                                        <div class="detail-item">
                                                                            <span class="detail-icon">🎨</span>
                                                                            <div>
                                                                                <span class="detail-label">Màu
                                                                                    sắc</span>
                                                                                <span class="detail-value">
                                                                                    <%= pet.color %>
                                                                                </span>
                                                                            </div>
                                                                        </div>
                                                                        <% } %>

                                                                            <% if (pet.vaccination) { %>
                                                                                <div class="detail-item">
                                                                                    <span class="detail-icon">💉</span>
                                                                                    <div>
                                                                                        <span class="detail-label">Tiêm
                                                                                            phòng</span>
                                                                                        <span class="detail-value">
                                                                                            <%= pet.vaccination %>
                                                                                        </span>
                                                                                    </div>
                                                                                </div>
                                                                                <% } %>

                                                                                    <% if (pet.contact_info) { %>
                                                                                        <div class="detail-item">
                                                                                            <span
                                                                                                class="detail-icon">📞</span>
                                                                                            <div>
                                                                                                <span
                                                                                                    class="detail-label">TNV
                                                                                                    liên hệ</span>
                                                                                                <span
                                                                                                    class="detail-value">
                                                                                                    <%= pet.contact_info
                                                                                                        %>
                                                                                                </span>
                                                                                            </div>
                                                                                        </div>
                                                                                        <% } %>
                                </div>

                                <!-- Pet Stats -->
                                <div class="pet-stats">
                                    <div class="stat-item">
                                        <span class="stat-icon">❤️</span>
                                        <span class="stat-value" id="likesCount"><%= typeof likesCount !== 'undefined' ? likesCount : 0 %></span>
                                        <span class="stat-label">Lượt thích</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-icon">👤</span>
                                        <span class="stat-value" id="pendingCount"><%= typeof pendingCount !== 'undefined' ? pendingCount : 0 %></span>
                                        <span class="stat-label">Người quan tâm</span>
                                    </div>
                                </div>

                                <% if (pet.status==='available' ) { %>
                                    <div class="adopt-actions">
                                        <% if (typeof isAuthenticated !=='undefined' && isAuthenticated) { %>
                                            <button class="btn btn-green btn-lg" id="adoptBtn"
                                                data-pet-id="<%= pet.id %>">
                                                🐾 Đăng ký nhận nuôi
                                            </button>
                                            <% } else { %>
                                                <a href="/auth/login" class="btn btn-green btn-lg">
                                                    🔐 Đăng nhập để nhận nuôi
                                                </a>
                                                <% } %>

                                                    <!-- Like (Favorite) Button -->
                                                    <% if (typeof isAuthenticated !=='undefined' && isAuthenticated) { %>
                                                        <button class="btn-like <%= (typeof isLiked !== 'undefined' && isLiked) ? 'liked' : '' %>"
                                                            id="likeBtn" data-pet-id="<%= pet.id %>" title="Yêu thích">
                                                            <span class="like-heart"><%= (typeof isLiked !== 'undefined' && isLiked) ? '❤️' : '🤍' %></span>
                                                        </button>
                                                    <% } %>

                                                    <button class="btn btn-outline-gray" id="shareBtn"
                                                        data-share-title="<%= (pet.name || '') + ' - Pet Helper' %>"
                                                        data-share-text="<%= pet.description || '' %>">
                                                        📤 Chia sẻ
                                                    </button>
                                    </div>
                                    <% } %>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>

            <script>
                // Adopt button
                const adoptBtn = document.getElementById('adoptBtn');
                if (adoptBtn) {
                    adoptBtn.addEventListener('click', () => {
                        const isUnverified = "<%= (typeof user !== 'undefined' && user && user.verify !== 1) ? 'true' : 'false' %>" === "true";

                        if (isUnverified) {
                            // User chưa xác thực email
                            Swal.fire({
                                title: 'Chưa xác minh email',
                                text: 'Bạn cần xác minh email trước khi nhận nuôi thú cưng.',
                                icon: 'warning',
                                showCancelButton: true,
                                confirmButtonColor: '#2b663e',
                                cancelButtonColor: '#64748B',
                                confirmButtonText: 'Đi xác minh',
                                cancelButtonText: 'Đóng'
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    window.location.href = '/profile';
                                }
                            });
                        } else {
                            // User đã xác thực → cho phép nhận nuôi
                            Swal.fire({
                                title: 'Đăng ký nhận nuôi',
                                html: `
                                    <p style="margin-bottom: 12px;">Vui lòng cho biết lý do bạn muốn nhận nuôi <b><%= pet.name %></b>:</p>
                                    <textarea id="adoptionMessage" class="swal2-textarea" placeholder="Ví dụ: Tôi có kinh nghiệm nuôi thú cưng và môi trường phù hợp..."></textarea>
                                `,
                                icon: 'info',
                                showCancelButton: true,
                                confirmButtonColor: '#10B981',
                                cancelButtonColor: '#64748B',
                                confirmButtonText: 'Gửi đăng ký',
                                cancelButtonText: 'Hủy',
                                preConfirm: () => {
                                    const message = document.getElementById('adoptionMessage').value.trim();
                                    if (!message) {
                                        Swal.showValidationMessage('Vui lòng nhập lý do nhận nuôi');
                                        return false;
                                    }
                                    return message;
                                }
                            }).then(async (result) => {
                                if (result.isConfirmed && result.value) {
                                    const message = result.value;
                                    try {
                                        const response = await fetch('/api/adoption-requests', {
                                            method: 'POST',
                                            headers: {
                                                'Content-Type': 'application/json'
                                            },
                                            body: JSON.stringify({
                                                petId: adoptBtn.dataset.petId,
                                                message
                                            })
                                        });

                                        const data = await response.json();
                                        if (!response.ok) {
                                            throw new Error(data.message || 'Không thể gửi yêu cầu nhận nuôi');
                                        }

                                        Swal.fire({
                                            title: 'Đăng ký thành công!',
                                            text: 'Hồ sơ của bạn đã được gửi và đang chờ xét duyệt.',
                                            icon: 'success',
                                            confirmButtonColor: '#10B981'
                                        });
                                    } catch (error) {
                                        Swal.fire({
                                            title: 'Không thể gửi yêu cầu',
                                            text: error.message || 'Đã xảy ra lỗi, vui lòng thử lại.',
                                            icon: 'error',
                                            confirmButtonColor: '#EF4444'
                                        });
                                    }
                                } else if (result.isConfirmed) {
                                    Swal.fire({
                                        title: 'Thiếu thông tin',
                                        text: 'Vui lòng nhập lý do nhận nuôi trước khi gửi.',
                                        icon: 'warning',
                                        confirmButtonColor: '#F59E0B'
                                    });
                                }
                            });
                        }
                    });
                }

                // Share button
                const shareBtn = document.getElementById('shareBtn');
                if (shareBtn) {
                    shareBtn.addEventListener('click', () => {
                        if (navigator.share) {
                            navigator.share({
                                title: shareBtn.dataset.shareTitle || 'Pet Helper',
                                text: shareBtn.dataset.shareText || '',
                                url: window.location.href
                            });
                        } else {
                            navigator.clipboard.writeText(window.location.href);
                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                icon: 'success',
                                title: 'Đã sao chép link!',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    });
                }
            </script>

            <script>
                // Gallery image switching
                function changeMainImage(src, thumbEl) {
                    const mainImg = document.getElementById('mainImage');
                    if (mainImg) {
                        mainImg.style.opacity = '0.3';
                        setTimeout(() => {
                            mainImg.src = src;
                            mainImg.onload = () => {
                                mainImg.style.opacity = '1';
                            };
                        }, 150);
                    }
                    // Update active state
                    document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
                    if (thumbEl) thumbEl.classList.add('active');
                }
            </script>

            <script>
                // Like / Unlike AJAX
                const likeBtn = document.getElementById('likeBtn');
                if (likeBtn) {
                    let isProcessing = false;

                    likeBtn.addEventListener('click', async () => {
                        if (isProcessing) return; // Debounce / prevent spam
                        isProcessing = true;
                        likeBtn.disabled = true;
                        likeBtn.style.opacity = '0.6';

                        const petId = likeBtn.dataset.petId;
                        const wasLiked = likeBtn.classList.contains('liked');
                        const method = wasLiked ? 'DELETE' : 'POST';

                        // Optimistic UI update
                        const heartSpan = likeBtn.querySelector('.like-heart');
                        const likesCountEl = document.getElementById('likesCount');
                        const oldCount = parseInt(likesCountEl.textContent) || 0;

                        if (wasLiked) {
                            likeBtn.classList.remove('liked');
                            heartSpan.textContent = '🤍';
                            likesCountEl.textContent = Math.max(0, oldCount - 1);
                        } else {
                            likeBtn.classList.add('liked');
                            heartSpan.textContent = '❤️';
                            likesCountEl.textContent = oldCount + 1;
                        }

                        try {
                            const response = await fetch(`/adopt/${petId}/like`, { method });
                            const data = await response.json();

                            if (!response.ok) {
                                throw new Error(data.message || 'Lỗi');
                            }

                            // Sync with server truth
                            likesCountEl.textContent = data.totalLikes;
                            if (data.isLiked) {
                                likeBtn.classList.add('liked');
                                heartSpan.textContent = '❤️';
                            } else {
                                likeBtn.classList.remove('liked');
                                heartSpan.textContent = '🤍';
                            }

                            // Show favorite overlay feedback
                            if (typeof showFavoriteOverlay === 'function') {
                                showFavoriteOverlay(data.isLiked);
                            }

                            if (typeof refreshFavoritesOverlay === 'function') {
                                refreshFavoritesOverlay();
                            }
                        } catch (error) {
                            // Rollback on failure
                            if (wasLiked) {
                                likeBtn.classList.add('liked');
                                heartSpan.textContent = '❤️';
                                likesCountEl.textContent = oldCount;
                            } else {
                                likeBtn.classList.remove('liked');
                                heartSpan.textContent = '🤍';
                                likesCountEl.textContent = oldCount;
                            }
                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                icon: 'error',
                                title: error.message || 'Không thể thực hiện',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        } finally {
                            isProcessing = false;
                            likeBtn.disabled = false;
                            likeBtn.style.opacity = '1';
                        }
                    });
                }
            </script>

            <style>
                .pet-detail-page {
                    padding: 40px 0 80px;
                }

                .back-link {
                    display: inline-block;
                    color: var(--primary);
                    font-weight: 500;
                    margin-bottom: 30px;
                }

                .back-link:hover {
                    text-decoration: underline;
                }

                .pet-detail-grid {
                    display: grid;
                    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
                    gap: 50px;
                    align-items: start;
                }

                .pet-image-section {
                    position: relative;
                    width: 100%;
                    max-width: 30rem;
                }

                .pet-info-section {
                    min-width: 0;
                }

                .pet-main-image {
                    width: 30rem;
                    height: 30rem;
                    max-width: 100%;
                    border-radius: 20px;
                    box-shadow: var(--shadow-lg);
                    transition: opacity 0.3s ease;
                    object-fit: cover;
                    object-position: center;
                    aspect-ratio: 1 / 1;
                    display: block;
                }

                .pet-gallery {
                    display: flex;
                    gap: 10px;
                    margin-top: 15px;
                    overflow-x: auto;
                    padding-bottom: 5px;
                    width: 100%;
                    max-width: 30rem;
                }

                .pet-gallery-dropdown {
                    margin-top: 8px;
                    width: 100%;
                    max-width: 30rem;
                }

                .pet-gallery-dropdown summary {
                    cursor: pointer;
                    color: var(--primary);
                    font-weight: 600;
                    list-style: none;
                    user-select: none;
                }

                .pet-gallery-dropdown summary::-webkit-details-marker {
                    display: none;
                }

                .pet-gallery-dropdown summary::before {
                    content: '▾ ';
                    font-size: 0.9rem;
                }

                .pet-gallery-dropdown[open] summary::before {
                    content: '▴ ';
                }

                .pet-gallery-extra {
                    margin-top: 10px;
                }

                .gallery-thumb {
                    flex-shrink: 0;
                    width: 80px;
                    height: 80px;
                    border-radius: 12px;
                    overflow: hidden;
                    cursor: pointer;
                    border: 3px solid transparent;
                    transition: all 0.3s ease;
                    opacity: 0.6;
                }

                .gallery-thumb:hover {
                    opacity: 0.9;
                    transform: scale(1.05);
                }

                .gallery-thumb.active {
                    border-color: var(--primary, #2d6a4f);
                    opacity: 1;
                    box-shadow: 0 2px 8px rgba(45, 106, 79, 0.3);
                }

                .gallery-thumb img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

                .pet-status-badge {
                    position: absolute;
                    top: 20px;
                    left: 20px;
                    padding: 8px 16px;
                    border-radius: 20px;
                    font-size: 0.85rem;
                    font-weight: 600;
                    background: white;
                }

                .pet-species-tag {
                    display: inline-block;
                    background: var(--bg-main);
                    padding: 8px 16px;
                    border-radius: 20px;
                    font-size: 0.9rem;
                    color: var(--primary);
                    font-weight: 500;
                    margin-bottom: 15px;
                }

                .pet-name {
                    font-size: 2.5rem;
                    color: var(--text-primary);
                    margin-bottom: 15px;
                }

                .pet-description {
                    color: var(--text-secondary);
                    font-size: 1.1rem;
                    line-height: 1.7;
                    margin-bottom: 30px;
                }

                .pet-details-grid {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 20px;
                    margin-bottom: 30px;
                }

                .detail-item {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    padding: 15px;
                    background: var(--bg-main);
                    border-radius: 12px;
                }

                .detail-icon {
                    font-size: 1.5rem;
                }

                .detail-label {
                    display: block;
                    font-size: 0.8rem;
                    color: var(--text-secondary);
                }

                .detail-value {
                    font-weight: 600;
                    color: var(--text-primary);
                }

                .pet-stats {
                    display: flex;
                    gap: 25px;
                    margin-bottom: 25px;
                    padding: 16px 20px;
                    background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
                    border-radius: 14px;
                    border: 1px solid #d1fae5;
                }

                .stat-item {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                }

                .stat-icon {
                    font-size: 1.2rem;
                }

                .stat-value {
                    font-weight: 700;
                    font-size: 1.1rem;
                    color: #1b4332;
                }

                .stat-label {
                    font-size: 0.85rem;
                    color: #64748B;
                }

                .adopt-actions {
                    display: flex;
                    gap: 15px;
                    align-items: center;
                }

                .btn-lg {
                    padding: 16px 32px;
                    font-size: 1.1rem;
                }

                .btn-like {
                    width: 56px;
                    height: 56px;
                    border-radius: 50%;
                    border: 2px solid #e2e8f0;
                    background: #fff;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 1.5rem;
                    transition: all 0.3s ease;
                    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
                }

                .btn-like:hover {
                    transform: scale(1.15);
                    border-color: #f87171;
                    box-shadow: 0 4px 16px rgba(248, 113, 113, 0.3);
                }

                .btn-like.liked {
                    border-color: #ef4444;
                    background: #fef2f2;
                    animation: heartPop 0.4s ease;
                }

                @keyframes heartPop {
                    0% { transform: scale(1); }
                    50% { transform: scale(1.3); }
                    100% { transform: scale(1); }
                }

                .btn-outline-gray {
                    background: transparent;
                    border: 2px solid var(--border);
                    color: var(--text-secondary);
                }

                .btn-outline-gray:hover {
                    border-color: var(--primary);
                    color: var(--primary);
                }

                @media (max-width: 768px) {
                    .pet-detail-grid {
                        grid-template-columns: 1fr;
                        gap: 30px;
                    }

                    .pet-image-section {
                        max-width: 22rem;
                    }

                    .pet-main-image {
                        width: 100%;
                        max-width: 22rem;
                        height: auto;
                    }

                    .pet-name {
                        font-size: 2rem;
                    }

                    .pet-details-grid {
                        grid-template-columns: 1fr;
                    }

                    .adopt-actions {
                        flex-direction: column;
                    }

                    .pet-stats {
                        flex-direction: column;
                        gap: 12px;
                    }
                }
            </style>
</body>

</html>
