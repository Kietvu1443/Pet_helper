<!-- ============ FAVORITE SUCCESS OVERLAY ============ -->
<div id="favorite-overlay" class="auth-overlay" role="dialog" aria-modal="true" aria-label="Đã yêu thích">
    <div class="auth-overlay__backdrop" onclick="closeOverlay('favorite-overlay')"></div>
    <div class="fav-overlay-modal">
        <button class="auth-overlay__close" onclick="closeOverlay('favorite-overlay')" aria-label="Đóng">&times;</button>

        <div class="fav-overlay-content">
            <div class="fav-overlay-icon" id="favOverlayIcon">❤️</div>
            <h3 class="fav-overlay-title" id="favOverlayTitle">Đã thêm vào yêu thích</h3>
            <p class="fav-overlay-subtitle" id="favOverlaySubtitle">Bạn có thể xem lại danh sách thú cưng yêu thích bất cứ lúc nào</p>
            <a href="/favorites" class="fav-overlay-btn">
                🐾 Xem danh sách yêu thích
            </a>
        </div>
    </div>
</div>

<!-- ============ FAVORITES QUICK OVERLAY ============ -->
<div id="favorites-overlay" class="report-overlay favorites-quick-overlay" role="dialog" aria-modal="true" aria-label="Thú cưng yêu thích">
    <div class="report-overlay-backdrop" onclick="closeOverlay('favorites-overlay')"></div>
    <div class="report-overlay-modal favorites-quick-overlay__modal">
        <button
            type="button"
            class="report-overlay-close favorites-quick-overlay__close"
            onclick="closeOverlay('favorites-overlay')"
            aria-label="Đóng"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>

        <div class="favorites-quick-overlay__header">
            <div>
                <h3>Thú cưng yêu thích</h3>
                <p>Xem nhanh danh sách mới nhất của bạn</p>
            </div>
            <a href="/favorites" class="favorites-quick-overlay__manage-link">Quản lý đầy đủ</a>
        </div>

        <div class="favorites-quick-overlay__body">
            <div id="favoritesQuickState" class="favorites-quick-overlay__state"></div>
            <div id="favoritesQuickList" class="favorites-quick-overlay__list"></div>
        </div>

        <div class="favorites-quick-overlay__footer">
            <a href="/favorites" class="favorites-quick-overlay__footer-btn">Mở trang Thú cưng yêu thích</a>
        </div>
    </div>
</div>

<style>
    .fav-overlay-modal {
        position: relative;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        width: 90%;
        max-width: 360px;
        border-radius: 24px;
        padding: 40px 32px 32px;
        box-shadow:
            0 25px 60px rgba(0, 0, 0, 0.18),
            0 0 0 1px rgba(255, 255, 255, 0.3) inset;
        transform: scale(0.85) translateY(30px);
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        text-align: center;
    }

    .auth-overlay.active .fav-overlay-modal {
        transform: scale(1) translateY(0);
    }

    .fav-overlay-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

    .fav-overlay-icon {
        font-size: 3.5rem;
        animation: favBounce 0.6s ease;
    }

    @keyframes favBounce {
        0% { transform: scale(0); opacity: 0; }
        50% { transform: scale(1.3); }
        70% { transform: scale(0.9); }
        100% { transform: scale(1); opacity: 1; }
    }

    .fav-overlay-title {
        color: #1b4332;
        font-size: 1.3rem;
        font-weight: 700;
        margin: 0;
    }

    .fav-overlay-subtitle {
        color: #64748B;
        font-size: 0.9rem;
        margin: 0;
        line-height: 1.5;
    }

    .fav-overlay-btn {
        display: inline-block;
        margin-top: 8px;
        padding: 12px 28px;
        background: linear-gradient(135deg, #2d6a4f, #40916c);
        color: #fff;
        text-decoration: none;
        border-radius: 14px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(45, 106, 79, 0.3);
    }

    .fav-overlay-btn:hover {
        background: linear-gradient(135deg, #1b4332, #2d6a4f);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(45, 106, 79, 0.4);
    }

    .favorites-quick-overlay.report-overlay {
        position: fixed;
        inset: 0;
        z-index: 5200;
        display: flex;
        align-items: center;
        justify-content: center;
        visibility: hidden;
        opacity: 0;
        transition: opacity 0.35s ease, visibility 0.35s ease;
    }

    .favorites-quick-overlay.report-overlay.active {
        visibility: visible;
        opacity: 1;
    }

    .favorites-quick-overlay .report-overlay-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.52);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }

    .favorites-quick-overlay .report-overlay-modal {
        position: relative;
        z-index: 1;
        width: 95%;
        max-width: 640px;
        max-height: 86vh;
        overflow-y: auto;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 22px 56px rgba(0, 0, 0, 0.28);
        transform: scale(0.94) translateY(16px);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .favorites-quick-overlay.report-overlay.active .report-overlay-modal {
        transform: scale(1) translateY(0);
    }

    .favorites-quick-overlay__close {
        position: absolute;
        top: 12px;
        right: 12px;
        border: none;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.25);
        color: #ffffff;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .favorites-quick-overlay__header {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
        padding: 18px 18px 14px;
        color: #ffffff;
        background: linear-gradient(135deg, #b42318, #d64545);
        border-radius: 16px 16px 0 0;
    }

    .favorites-quick-overlay__header h3 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    .favorites-quick-overlay__header p {
        margin: 6px 0 0;
        font-size: 0.85rem;
        opacity: 0.9;
    }

    .favorites-quick-overlay__manage-link {
        text-decoration: none;
        white-space: nowrap;
        padding: 8px 12px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.2);
        color: #ffffff;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .favorites-quick-overlay__body {
        background: #fff7f7;
        padding: 14px 16px;
    }

    .favorites-quick-overlay__state {
        margin-bottom: 12px;
        font-size: 0.85rem;
        color: #6b7280;
        min-height: 22px;
    }

    .favorites-quick-overlay__list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .favorites-quick-overlay__item {
        display: grid;
        grid-template-columns: 56px 1fr auto;
        gap: 12px;
        align-items: center;
        background: #ffffff;
        border: 1px solid #fecaca;
        border-radius: 12px;
        padding: 10px;
    }

    .favorites-quick-overlay__thumb {
        width: 56px;
        height: 56px;
        border-radius: 10px;
        object-fit: cover;
        background: #fee2e2;
    }

    .favorites-quick-overlay__meta {
        min-width: 0;
    }

    .favorites-quick-overlay__name {
        margin: 0 0 4px;
        color: #111827;
        font-size: 0.9rem;
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .favorites-quick-overlay__sub {
        margin: 0;
        font-size: 0.78rem;
        color: #6b7280;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .favorites-quick-overlay__status {
        display: inline-block;
        margin-top: 6px;
        font-size: 0.74rem;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 999px;
    }

    .favorites-quick-overlay__status.available {
        background: #dcfce7;
        color: #166534;
    }

    .favorites-quick-overlay__status.unavailable {
        background: #fee2e2;
        color: #991b1b;
    }

    .favorites-quick-overlay__detail-link {
        text-decoration: none;
        font-size: 0.78rem;
        font-weight: 700;
        color: #b42318;
        background: #fee2e2;
        border-radius: 8px;
        padding: 7px 10px;
        white-space: nowrap;
    }

    .favorites-quick-overlay__footer {
        display: flex;
        justify-content: flex-end;
        padding: 12px 16px 16px;
        border-top: 1px solid #fecaca;
        background: #ffffff;
        border-radius: 0 0 16px 16px;
    }

    .favorites-quick-overlay__footer-btn {
        text-decoration: none;
        background: #b42318;
        color: #ffffff;
        font-weight: 700;
        font-size: 0.85rem;
        padding: 9px 14px;
        border-radius: 10px;
    }

    .favorites-quick-overlay__skeleton {
        height: 74px;
        border-radius: 12px;
        background: linear-gradient(90deg, #fee2e2 25%, #fecaca 37%, #fee2e2 63%);
        background-size: 400% 100%;
        animation: favoritesShimmer 1.2s infinite;
    }

    @keyframes favoritesShimmer {
        0% {
            background-position: 100% 0;
        }
        100% {
            background-position: 0 0;
        }
    }

    @media (max-width: 480px) {
        .fav-overlay-modal {
            padding: 32px 20px 24px;
            border-radius: 20px;
        }

        .fav-overlay-icon {
            font-size: 2.8rem;
        }

        .fav-overlay-title {
            font-size: 1.15rem;
        }

        .favorites-quick-overlay .report-overlay-modal {
            width: 96%;
        }

        .favorites-quick-overlay__header {
            padding: 16px 14px 12px;
            flex-direction: column;
        }

        .favorites-quick-overlay__body {
            padding: 12px;
        }

        .favorites-quick-overlay__item {
            grid-template-columns: 48px 1fr;
            gap: 10px;
            padding: 8px;
        }

        .favorites-quick-overlay__thumb {
            width: 48px;
            height: 48px;
        }

        .favorites-quick-overlay__detail-link {
            grid-column: 1 / -1;
            justify-self: flex-start;
        }
    }
</style>

<script>
    // Auto-timer reference for favorite overlay
    window._favOverlayTimer = window._favOverlayTimer || null;

    function showFavoriteOverlay(isLiked) {
        const icon = document.getElementById('favOverlayIcon');
        const title = document.getElementById('favOverlayTitle');
        const subtitle = document.getElementById('favOverlaySubtitle');

        if (isLiked) {
            icon.textContent = '❤️';
            title.textContent = 'Đã thêm vào yêu thích';
            subtitle.textContent = 'Bạn có thể xem lại danh sách thú cưng yêu thích bất cứ lúc nào';
        } else {
            icon.textContent = '🤍';
            title.textContent = 'Đã bỏ yêu thích';
            subtitle.textContent = 'Thú cưng này đã được xóa khỏi danh sách yêu thích của bạn';
        }

        // Re-trigger bounce animation
        icon.style.animation = 'none';
        void icon.offsetWidth;
        icon.style.animation = 'favBounce 0.6s ease';

        openOverlay('favorite-overlay');

        // Auto close after 3 seconds
        clearTimeout(window._favOverlayTimer);
        window._favOverlayTimer = setTimeout(() => {
            closeOverlay('favorite-overlay');
        }, 3000);
    }

    (function () {
        if (window.favoritesOverlayInitialized) return;
        window.favoritesOverlayInitialized = true;

        var OVERLAY_ID = 'favorites-overlay';
        var QUICK_LIMIT = 8;
        var inFlightRequest = null;

        function escapeHtml(str) {
            return String(str || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function setState(message, isError) {
            var stateEl = document.getElementById('favoritesQuickState');
            if (!stateEl) return;
            stateEl.textContent = message || '';
            stateEl.style.color = isError ? '#b91c1c' : '#6b7280';
        }

        function formatDate(input) {
            if (!input) return 'Không rõ thời gian';
            return new Date(input).toLocaleDateString('vi-VN');
        }

        function getStatusLabel(status) {
            if (status === 'available') {
                return { text: 'Sẵn sàng nhận nuôi', className: 'available' };
            }
            return { text: 'Đã có chủ', className: 'unavailable' };
        }

        function renderLoading() {
            var listEl = document.getElementById('favoritesQuickList');
            if (!listEl) return;
            setState('Đang tải danh sách yêu thích...', false);
            listEl.innerHTML = [
                '<div class="favorites-quick-overlay__skeleton"></div>',
                '<div class="favorites-quick-overlay__skeleton"></div>',
                '<div class="favorites-quick-overlay__skeleton"></div>'
            ].join('');
        }

        function renderItems(items) {
            var listEl = document.getElementById('favoritesQuickList');
            if (!listEl) return;

            if (!items || items.length === 0) {
                setState('Bạn chưa có thú cưng yêu thích nào.', false);
                listEl.innerHTML = '';
                return;
            }

            setState('Hiển thị ' + items.length + ' thú cưng yêu thích gần nhất.', false);

            listEl.innerHTML = items.map(function (item) {
                var safeImage = escapeHtml(item.image || '/images/logo.svg');
                var safeName = escapeHtml(item.name || 'Thú cưng');
                var safeType = escapeHtml(item.pet_type || 'Khác');
                var safeDesc = escapeHtml(item.description || 'Chưa có mô tả');
                var statusInfo = getStatusLabel(item.status);
                var safeStatus = escapeHtml(statusInfo.className);
                var safeStatusText = escapeHtml(statusInfo.text);
                var detailUrl = '/adopt/' + encodeURIComponent(item.id);

                return [
                    '<div class="favorites-quick-overlay__item">',
                    '  <img class="favorites-quick-overlay__thumb" src="' + safeImage + '" alt="' + safeName + '" onerror="this.onerror=null;this.src=\'/images/logo.svg\'">',
                    '  <div class="favorites-quick-overlay__meta">',
                    '    <p class="favorites-quick-overlay__name">' + safeName + '</p>',
                    '    <p class="favorites-quick-overlay__sub">🐾 ' + safeType + ' · ❤️ ' + formatDate(item.liked_at) + '</p>',
                    '    <p class="favorites-quick-overlay__sub">' + safeDesc + '</p>',
                    '    <span class="favorites-quick-overlay__status ' + safeStatus + '">' + safeStatusText + '</span>',
                    '  </div>',
                    '  <a href="' + detailUrl + '" class="favorites-quick-overlay__detail-link">Xem chi tiết</a>',
                    '</div>'
                ].join('');
            }).join('');
        }

        function fetchRecentFavorites() {
            if (inFlightRequest) {
                return inFlightRequest;
            }

            renderLoading();

            inFlightRequest = fetch('/api/favorites?limit=' + QUICK_LIMIT)
                .then(function (res) {
                    if (!res.ok) {
                        throw new Error('Không thể tải danh sách yêu thích');
                    }
                    return res.json();
                })
                .then(function (json) {
                    return Array.isArray(json.data) ? json.data : [];
                })
                .finally(function () {
                    inFlightRequest = null;
                });

            return inFlightRequest;
        }

        window.loadFavoritesOverlay = async function () {
            try {
                var items = await fetchRecentFavorites();
                renderItems(items);
            } catch (error) {
                setState(error.message || 'Không thể tải danh sách yêu thích.', true);
                var listEl = document.getElementById('favoritesQuickList');
                if (listEl) listEl.innerHTML = '';
            }
        };

        window.openFavoritesOverlay = function (event) {
            if (event && typeof event.preventDefault === 'function') {
                event.preventDefault();
            }

            var overlay = document.getElementById(OVERLAY_ID);
            if (!overlay) {
                window.location.href = '/favorites';
                return false;
            }

            if (typeof openOverlay === 'function') {
                openOverlay(OVERLAY_ID);
            } else {
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            window.loadFavoritesOverlay();
            return false;
        };

        window.refreshFavoritesOverlay = function () {
            return window.loadFavoritesOverlay();
        };
    })();
</script>
