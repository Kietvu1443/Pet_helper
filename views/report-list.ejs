<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .card-img { width: 100%; height: 200px; object-fit: cover; }
        .badge-lost { background-color: #fee2e2; color: #b91c1c; }
        .badge-found { background-color: #dcfce7; color: #166534; }
    </style>
</head>

<body class="bg-gray-50 min-h-screen">

    <!-- Header -->
    <header class="bg-[#2a6b47] text-white">
        <div class="max-w-7xl mx-auto px-4 py-6 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3 text-white no-underline">
                <div class="bg-white text-[#2a6b47] w-10 h-10 rounded-full flex items-center justify-center font-black text-sm">PET</div>
                <h1 class="text-xl font-bold tracking-wide">PET HELPER</h1>
            </a>
            <nav class="flex gap-6 text-sm font-semibold uppercase">
                <a href="/adopt" class="text-white/80 hover:text-white transition-colors">Nhận nuôi</a>
                <a href="/reports/list" class="text-white border-b-2 border-white pb-0.5">Thất lạc & Tìm thấy</a>
            </nav>
        </div>
    </header>

    <% if (typeof submitted !== 'undefined') { %>
    <div class="max-w-7xl mx-auto px-4 mt-6">
        <div class="bg-green-50 border border-green-200 text-green-800 px-6 py-4 rounded-xl text-sm font-medium">
            ✅ Báo cáo của bạn đã được gửi thành công! Vui lòng chờ quản trị viên phê duyệt.
        </div>
    </div>
    <% } %>

    <main class="max-w-7xl mx-auto px-4 py-10">
        <!-- Lost Pets Section -->
        <section class="mb-16">
            <div class="flex items-center gap-3 mb-6">
                <span class="px-3 py-1 rounded-full text-sm font-bold badge-lost">🔴 THẤT LẠC</span>
                <h2 class="text-2xl font-bold text-gray-800">Thú cưng đang thất lạc</h2>
            </div>
            <div id="lost-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <div class="col-span-full text-center text-gray-400 py-8">Đang tải...</div>
            </div>
            <div id="lost-pagination" class="flex justify-center mt-6 gap-2"></div>
        </section>

        <!-- Found Pets Section -->
        <section>
            <div class="flex items-center gap-3 mb-6">
                <span class="px-3 py-1 rounded-full text-sm font-bold badge-found">🟢 TÌM THẤY</span>
                <h2 class="text-2xl font-bold text-gray-800">Thú cưng đã tìm thấy</h2>
            </div>
            <div id="found-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <div class="col-span-full text-center text-gray-400 py-8">Đang tải...</div>
            </div>
            <div id="found-pagination" class="flex justify-center mt-6 gap-2"></div>
        </section>
    </main>

    <!-- Quick Actions -->
    <div class="fixed bottom-6 right-6 flex flex-col gap-3 z-50">
        <a href="/lost" class="bg-red-500 hover:bg-red-600 text-white px-5 py-3 rounded-full shadow-lg font-semibold text-sm transition-all hover:-translate-y-0.5 flex items-center gap-2">
            🆘 Đăng Tin Thất Lạc
        </a>
        <a href="/found" class="bg-emerald-500 hover:bg-emerald-600 text-white px-5 py-3 rounded-full shadow-lg font-semibold text-sm transition-all hover:-translate-y-0.5 flex items-center gap-2">
            🏠 Báo Đã Tìm Thấy
        </a>
    </div>

    <script>
        const LIMIT = 8;
        let lostPage = 1;
        let foundPage = 1;

        function renderCard(report) {
            const badgeClass = report.type === 'lost' ? 'badge-lost' : 'badge-found';
            const badgeText = report.type === 'lost' ? 'Thất lạc' : 'Tìm thấy';
            return `
                <div class="bg-white rounded-xl shadow-sm overflow-hidden hover:shadow-md transition-shadow border border-gray-100">
                    <div class="relative">
                        <img src="${report.image || '/images/logo.svg'}" alt="Pet" class="card-img"
                             onerror="this.src='/images/logo.svg'">
                        <span class="absolute top-3 left-3 px-2 py-1 rounded-full text-xs font-bold ${badgeClass}">${badgeText}</span>
                    </div>
                    <div class="p-4">
                        <p class="text-gray-700 text-sm line-clamp-2 mb-3">${report.description || 'Không có mô tả'}</p>
                        <div class="flex items-center gap-1 text-xs text-gray-500 mb-1">
                            <span>📍</span>
                            <span class="truncate">${report.location || 'Chưa rõ'}</span>
                        </div>
                        <div class="flex items-center gap-1 text-xs text-gray-500 mb-1">
                            <span>👤</span>
                            <span>${report.reporter_name || 'Ẩn danh'}</span>
                        </div>
                        <div class="flex items-center gap-1 text-xs text-emerald-700 font-semibold">
                            <span>📞</span>
                            <a href="tel:${report.phone}" class="hover:underline">${report.phone}</a>
                        </div>
                    </div>
                </div>
            `;
        }

        function renderPagination(containerId, currentPage, totalPages, onPageClick) {
            const container = document.getElementById(containerId);
            if (totalPages <= 1) { container.innerHTML = ''; return; }
            let html = '';
            for (let i = 1; i <= totalPages; i++) {
                const active = i === currentPage ? 'bg-[#2a6b47] text-white' : 'bg-white text-gray-700 hover:bg-gray-100';
                html += `<button onclick="${onPageClick}(${i})" class="px-3 py-1.5 rounded-lg text-sm font-semibold border border-gray-200 ${active} transition-colors">${i}</button>`;
            }
            container.innerHTML = html;
        }

        async function loadLost(page) {
            lostPage = page;
            try {
                const res = await fetch(`/api/reports?type=lost&page=${page}&limit=${LIMIT}`);
                const json = await res.json();
                const grid = document.getElementById('lost-grid');
                if (!json.data || json.data.length === 0) {
                    grid.innerHTML = '<div class="col-span-full text-center text-gray-400 py-8">Chưa có thú cưng thất lạc nào được báo cáo.</div>';
                } else {
                    grid.innerHTML = json.data.map(renderCard).join('');
                }
                renderPagination('lost-pagination', page, json.totalPages, 'loadLost');
            } catch (e) {
                document.getElementById('lost-grid').innerHTML = '<div class="col-span-full text-center text-red-500 py-8">Không thể tải dữ liệu.</div>';
            }
        }

        async function loadFound(page) {
            foundPage = page;
            try {
                const res = await fetch(`/api/reports?type=found&page=${page}&limit=${LIMIT}`);
                const json = await res.json();
                const grid = document.getElementById('found-grid');
                if (!json.data || json.data.length === 0) {
                    grid.innerHTML = '<div class="col-span-full text-center text-gray-400 py-8">Chưa có thú cưng nào được tìm thấy.</div>';
                } else {
                    grid.innerHTML = json.data.map(renderCard).join('');
                }
                renderPagination('found-pagination', page, json.totalPages, 'loadFound');
            } catch (e) {
                document.getElementById('found-grid').innerHTML = '<div class="col-span-full text-center text-red-500 py-8">Không thể tải dữ liệu.</div>';
            }
        }

        // Initial load
        loadLost(1);
        loadFound(1);
    </script>
</body>

</html>
