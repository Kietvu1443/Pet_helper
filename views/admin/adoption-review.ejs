<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --bg-body: #F4F7F6;
            --bg-surface: #FFFFFF;
            --text-main: #1A202C;
            --text-muted: #718096;
            --border-color: #E2E8F0;
            --hover-bg: #EDF2F7;
            --primary: #2b663e;
            --primary-light: #e6f0eb;
            --accent: #F59E0B;
            --danger: #E53E3E;
            --success: #38A169;
            --warning: #D69E2E;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }

        body { background: var(--bg-body); color: var(--text-main); min-height: 100vh; }

        /* Layout */
        .page-wrapper { display: flex; min-height: calc(100vh - 120px); }

        /* Sidebar */
        .sidebar {
            width: 240px;
            background: var(--bg-surface);
            border-right: 1px solid var(--border-color);
            padding: 24px 0;
            flex-shrink: 0;
        }

        .sidebar-title {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 0 20px 12px;
        }

        .sidebar-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 20px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-left: 3px solid transparent;
            transition: all 0.18s;
        }

        .sidebar-item:hover { background: var(--hover-bg); color: var(--primary); }

        .sidebar-item.active {
            color: var(--primary);
            background: var(--primary-light);
            border-left-color: var(--primary);
            font-weight: 700;
        }

        .sidebar-item i { font-size: 18px; }

        /* Main content */
        .main-content { flex: 1; padding: 32px; overflow-x: auto; }

        .page-title { font-size: 22px; font-weight: 700; color: var(--text-main); margin-bottom: 24px; }

        /* Tabs */
        .tabs { display: flex; gap: 4px; border-bottom: 2px solid var(--border-color); margin-bottom: 24px; }

        .tab-btn {
            padding: 10px 22px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            background: none;
            border: none;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
            transition: all 0.18s;
        }

        .tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); }
        .tab-btn:hover:not(.active) { color: var(--text-main); }

        .badge {
            display: inline-block;
            min-width: 20px;
            padding: 1px 6px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            background: var(--border-color);
            color: var(--text-muted);
            margin-left: 6px;
        }

        .tab-btn.active .badge { background: var(--primary); color: #fff; }

        /* Table */
        .table-card { background: var(--bg-surface); border-radius: 12px; box-shadow: 0 1px 6px rgba(0,0,0,0.06); overflow: hidden; }

        table { width: 100%; border-collapse: collapse; }

        thead th {
            background: var(--bg-body);
            padding: 12px 16px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        tbody tr { border-bottom: 1px solid var(--border-color); transition: background 0.15s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: var(--hover-bg); }

        td { padding: 14px 16px; font-size: 14px; vertical-align: middle; }

        .pet-cell { display: flex; align-items: center; gap: 10px; }
        .pet-avatar { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; background: var(--hover-bg); }
        .pet-avatar-placeholder { width: 40px; height: 40px; border-radius: 8px; background: var(--hover-bg); display:flex; align-items:center; justify-content:center; font-size:20px; }

        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }
        .status-pending  { background: #FEF3C7; color: #92400E; }
        .status-approved { background: #D1FAE5; color: #065F46; }
        .status-rejected { background: #FEE2E2; color: #991B1B; }
        .status-cancelled { background: #F3F4F6; color: #6B7280; }

        .action-btn {
            padding: 6px 14px;
            border-radius: 8px;
            border: none;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.15s;
        }
        .action-btn:hover { opacity: 0.85; }
        .btn-approve { background: var(--success); color: #fff; margin-right: 6px; }
        .btn-reject  { background: var(--danger);  color: #fff; margin-left: 4px; }
        .btn-detail  { background: var(--primary-light); color: var(--primary); margin-right: 6px; }

        /* Modal */
        .modal-overlay {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.45);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.open { display: flex; }

        .modal-card {
            background: var(--bg-surface);
            border-radius: 16px;
            width: 520px;
            max-width: 95vw;
            max-height: 85vh;
            overflow-y: auto;
            padding: 32px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            position: relative;
        }

        .modal-close {
            position: absolute; top: 16px; right: 16px;
            background: none; border: none; font-size: 22px; cursor: pointer; color: var(--text-muted);
        }

        .modal-title { font-size: 18px; font-weight: 700; margin-bottom: 20px; }

        .detail-row { display: flex; gap: 8px; margin-bottom: 12px; font-size: 14px; }
        .detail-label { font-weight: 600; min-width: 130px; color: var(--text-muted); }
        .detail-value { color: var(--text-main); word-break: break-word; }

        .modal-actions { display: flex; gap: 10px; margin-top: 24px; }
        .modal-actions .action-btn { flex: 1; padding: 10px; }

        /* Empty state */
        .empty-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
        .empty-state i { font-size: 48px; display: block; margin-bottom: 12px; }

        /* Loading spinner */
        .spinner { text-align: center; padding: 40px; color: var(--text-muted); font-size: 14px; }
    </style>
</head>

<body>
    <%- include('../partials/header') %>

    <div class="page-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-title">Quản trị</div>
            <a href="/adopt/admin/add" class="sidebar-item">
                <i class="ph ph-plus-circle"></i> Thêm thú cưng
            </a>
            <a href="/admin/adoption-review" class="sidebar-item active">
                <i class="ph ph-clipboard-text"></i> Xét duyệt thú cưng
            </a>
        </aside>

        <!-- Main content -->
        <main class="main-content">
            <h1 class="page-title">Xét duyệt yêu cầu nhận nuôi</h1>

            <!-- Tabs -->
            <div class="tabs">
                <button class="tab-btn active" data-tab="pending">
                    Chờ duyệt <span class="badge" id="badge-pending">0</span>
                </button>
                <button class="tab-btn" data-tab="approved">
                    Đã duyệt <span class="badge" id="badge-approved">0</span>
                </button>
                <button class="tab-btn" data-tab="rejected">
                    Đã từ chối <span class="badge" id="badge-rejected">0</span>
                </button>
            </div>

            <!-- Table area -->
            <div class="table-card" id="tableArea">
                <div class="spinner">Đang tải dữ liệu...</div>
            </div>
        </main>
    </div>

    <!-- Detail Modal -->
    <div class="modal-overlay" id="detailModal">
        <div class="modal-card">
            <button class="modal-close" id="modalClose" aria-label="Đóng">✕</button>
            <h2 class="modal-title">Chi tiết yêu cầu nhận nuôi</h2>
            <div id="modalBody"></div>
            <div class="modal-actions" id="modalActions"></div>
        </div>
    </div>

    <script>
        // ── State ──────────────────────────────────────────────────────────────
        let allRequests = [];
        let activeTab   = 'pending';

        // ── Bootstrap ─────────────────────────────────────────────────────────
        (async function init() {
            await loadRequests();
            setupTabs();
            setupModal();
        })();

        // ── Fetch all requests ─────────────────────────────────────────────────
        async function loadRequests() {
            try {
                const res = await fetch('/admin/api/adoption-requests', {
                    headers: buildAuthHeaders()
                });
                if (!res.ok) {
                    if (res.status === 403) {
                        document.getElementById('tableArea').innerHTML =
                            '<div class="empty-state"><i class="ph ph-lock"></i>Bạn không có quyền truy cập trang này.</div>';
                        return;
                    }
                    throw new Error('HTTP ' + res.status);
                }
                allRequests = await res.json();
                updateBadges();
                renderTable(activeTab);
            } catch (err) {
                console.error(err);
                document.getElementById('tableArea').innerHTML =
                    '<div class="empty-state"><i class="ph ph-warning"></i>Không thể tải dữ liệu. Vui lòng thử lại.</div>';
            }
        }

        // ── Auth helpers ───────────────────────────────────────────────────────
        function buildAuthHeaders() {
            const token = localStorage.getItem('token');
            return token ? { 'Authorization': 'Bearer ' + token } : {};
        }

        // ── Badges ─────────────────────────────────────────────────────────────
        function updateBadges() {
            ['pending', 'approved', 'rejected'].forEach(s => {
                document.getElementById('badge-' + s).textContent =
                    allRequests.filter(r => r.status === s).length;
            });
        }

        // ── Tabs ───────────────────────────────────────────────────────────────
        function setupTabs() {
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    activeTab = btn.dataset.tab;
                    renderTable(activeTab);
                });
            });
        }

        // ── Table render ───────────────────────────────────────────────────────
        function renderTable(status) {
            const rows = allRequests.filter(r => r.status === status);
            const area = document.getElementById('tableArea');

            if (!rows.length) {
                area.innerHTML = `
                    <div class="empty-state">
                        <i class="ph ph-clipboard-text"></i>
                        Không có yêu cầu nào ở trạng thái này.
                    </div>`;
                return;
            }

            const isPending = status === 'pending';
            area.innerHTML = `
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Thú cưng</th>
                            <th>Người xin nhận</th>
                            <th>Ngày gửi</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${rows.map(r => renderRow(r, isPending)).join('')}
                    </tbody>
                </table>`;
        }

        function formatDate(dateVal) {
            return dateVal ? new Date(dateVal).toLocaleDateString('vi-VN') : '—';
        }

        function renderRow(r, isPending) {
            const avatarHtml = r.petImage
                ? `<img class="pet-avatar" src="${escHtml(r.petImage)}" alt="${escHtml(r.petName)}">`
                : `<div class="pet-avatar-placeholder">🐾</div>`;

            return `
                <tr>
                    <td>${r.id}</td>
                    <td><div class="pet-cell">${avatarHtml}<span>${escHtml(r.petName)}</span></div></td>
                    <td>${escHtml(r.adopter)}</td>
                    <td>${formatDate(r.date)}</td>
                    <td><span class="status-badge status-${r.status}">${statusLabel(r.status)}</span></td>
                    <td>
                        <button class="action-btn btn-detail" onclick="openModal(${r.id})">Chi tiết</button>
                        ${isPending ? `
                        <button class="action-btn btn-approve" onclick="handleAction(${r.id},'approved')">✔ Duyệt</button>
                        <button class="action-btn btn-reject"  onclick="handleAction(${r.id},'rejected')">✘ Từ chối</button>` : ''}
                    </td>
                </tr>`;
        }

        // ── Modal ──────────────────────────────────────────────────────────────
        function setupModal() {
            document.getElementById('modalClose').addEventListener('click', closeModal);
            document.getElementById('detailModal').addEventListener('click', e => {
                if (e.target === e.currentTarget) closeModal();
            });
        }

        function openModal(id) {
            const r = allRequests.find(x => x.id === id);
            if (!r) return;

            document.getElementById('modalBody').innerHTML = `
                <div class="detail-row"><span class="detail-label">Mã yêu cầu:</span><span class="detail-value">#${r.id}</span></div>
                <div class="detail-row"><span class="detail-label">Thú cưng:</span><span class="detail-value">${escHtml(r.petName)}</span></div>
                <div class="detail-row"><span class="detail-label">Người xin nhận:</span><span class="detail-value">${escHtml(r.adopter)}</span></div>
                <div class="detail-row"><span class="detail-label">Ngày gửi:</span><span class="detail-value">${formatDate(r.date)}</span></div>
                <div class="detail-row"><span class="detail-label">Trạng thái:</span><span class="detail-value"><span class="status-badge status-${r.status}">${statusLabel(r.status)}</span></span></div>
                <div class="detail-row"><span class="detail-label">Ngày xét duyệt:</span><span class="detail-value">${formatDate(r.reviewedAt)}</span></div>
                <div class="detail-row"><span class="detail-label">Lời nhắn:</span><span class="detail-value">${escHtml(r.message || '(Không có)')}</span></div>
            `;

            const actionsEl = document.getElementById('modalActions');
            if (r.status === 'pending') {
                actionsEl.innerHTML = `
                    <button class="action-btn btn-approve" onclick="handleAction(${r.id},'approved');closeModal()">✔ Duyệt yêu cầu</button>
                    <button class="action-btn btn-reject"  onclick="handleAction(${r.id},'rejected');closeModal()">✘ Từ chối</button>`;
            } else {
                actionsEl.innerHTML = '';
            }

            document.getElementById('detailModal').classList.add('open');
        }

        function closeModal() {
            document.getElementById('detailModal').classList.remove('open');
        }

        // ── Approve / Reject ───────────────────────────────────────────────────
        async function handleAction(id, status) {
            const label = status === 'approved' ? 'duyệt' : 'từ chối';
            const result = await Swal.fire({
                title: `Xác nhận ${label}?`,
                text: status === 'approved'
                    ? 'Hành động này sẽ duyệt yêu cầu và từ chối các yêu cầu khác cho cùng thú cưng.'
                    : 'Yêu cầu sẽ bị từ chối.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: status === 'approved' ? '#38A169' : '#E53E3E',
                cancelButtonColor: '#718096',
                confirmButtonText: `Xác nhận ${label}`,
                cancelButtonText: 'Huỷ',
            });

            if (!result.isConfirmed) return;

            try {
                const res = await fetch(`/admin/api/adoption-requests/${id}/status`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                        ...buildAuthHeaders()
                    },
                    body: JSON.stringify({ status })
                });

                if (!res.ok) {
                    const data = await res.json().catch(() => ({}));
                    throw new Error(data.message || 'Lỗi không xác định');
                }

                await Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: `Đã ${label} yêu cầu #${id}`,
                    timer: 1800,
                    showConfirmButton: false
                });

                await loadRequests();
            } catch (err) {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: err.message });
            }
        }

        // ── Utilities ──────────────────────────────────────────────────────────
        function statusLabel(s) {
            return { pending: 'Chờ duyệt', approved: 'Đã duyệt', rejected: 'Từ chối', cancelled: 'Đã huỷ' }[s] || s;
        }

        function escHtml(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }
    </script>
</body>
</html>
