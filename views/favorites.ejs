<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Danh sách thú cưng bạn đã yêu thích trên Pet Helper">
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        .favorites-page {
            padding: 40px 0 80px;
            min-height: 60vh;
        }

        .favorites-header {
            text-align: center;
            padding: 50px 20px 40px;
            background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 50%, #d1fae5 100%);
            border-bottom: 1px solid #d1fae5;
            margin-bottom: 40px;
        }

        .favorites-header-icon {
            font-size: 3rem;
            display: block;
            margin-bottom: 12px;
            animation: favHeaderPulse 2s ease-in-out infinite;
        }

        @keyframes favHeaderPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .favorites-header h1 {
            color: #1b4332;
            font-size: 2rem;
            font-weight: 800;
            margin: 0 0 8px 0;
        }

        .favorites-header p {
            color: #64748B;
            font-size: 1rem;
            margin: 0;
        }

        .favorites-count {
            display: inline-block;
            margin-top: 12px;
            padding: 6px 18px;
            background: rgba(45, 106, 79, 0.1);
            color: #2d6a4f;
            border-radius: 20px;
            font-weight: 700;
            font-size: 0.9rem;
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
            padding: 0 20px;
        }

        .pet-card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
            position: relative;
        }

        .pet-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
        }

        .pet-card.is-adopted {
            opacity: 0.7;
        }

        .card-image {
            width: 100%;
            height: 220px;
            object-fit: cover;
        }

        .card-body {
            padding: 20px;
        }

        .card-tag {
            display: inline-block;
            padding: 4px 12px;
            background: #ecfdf5;
            color: #2d6a4f;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .card-tag-adopted {
            background: #fef2f2;
            color: #dc2626;
        }

        .card-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 10px;
            color: #1b4332;
        }

        .card-text {
            color: #64748B;
            font-size: 0.95rem;
            margin-bottom: 15px;
            line-height: 1.5;
        }

        .pet-info {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 15px;
            font-size: 0.85rem;
            color: #64748B;
        }

        .card-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            color: #64748B;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }

        .btn-green {
            display: inline-block;
            padding: 8px 20px;
            background: linear-gradient(135deg, #2d6a4f, #40916c);
            color: #fff;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.3s ease;
        }

        .btn-green:hover {
            background: linear-gradient(135deg, #1b4332, #2d6a4f);
            transform: translateY(-1px);
        }

        .btn-unlike {
            background: none;
            border: 2px solid #e2e8f0;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .btn-unlike:hover {
            border-color: #f87171;
            background: #fef2f2;
            transform: scale(1.1);
        }

        .empty-state {
            text-align: center;
            padding: 80px 20px;
        }

        .empty-icon {
            font-size: 4rem;
            margin-bottom: 20px;
        }

        .empty-state h3 {
            color: #1b4332;
            margin-bottom: 10px;
            font-size: 1.4rem;
        }

        .empty-state p {
            color: #64748B;
            margin-bottom: 25px;
        }

        .liked-at {
            font-size: 0.78rem;
            color: #94a3b8;
        }

        @media (max-width: 768px) {
            .card-grid {
                grid-template-columns: 1fr;
            }

            .favorites-header h1 {
                font-size: 1.5rem;
            }
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

    <!-- Header -->
    <section class="favorites-header">
        <span class="favorites-header-icon">❤️</span>
        <h1>Thú Cưng Yêu Thích</h1>
        <p>Danh sách những bé thú cưng bạn đã bày tỏ yêu thích</p>
        <% if (pets && pets.length > 0) { %>
            <div class="favorites-count">
                <%= pets.length %> thú cưng yêu thích
            </div>
        <% } %>
    </section>

    <!-- Pet Grid -->
    <section class="favorites-page">
        <div class="container">
            <% if (pets && pets.length > 0) { %>
                <div class="card-grid" id="favoritesGrid">
                    <% pets.forEach(function(pet) { %>
                        <div class="pet-card <%= pet.status !== 'available' ? 'is-adopted' : '' %>" id="favCard-<%= pet.id %>">
                            <img src="<%= pet.avatar_image || pet.image_url || 'https://via.placeholder.com/400x220?text=No+Image' %>"
                                alt="<%= pet.name %>" class="card-image"
                                onerror="this.src='https://via.placeholder.com/400x220?text=No+Image'">
                            <div class="card-body">
                                <span class="card-tag">
                                    <%= pet.pet_type==='Chó' ? '🐕 Chó' : pet.pet_type==='Mèo' ? '🐱 Mèo' : '🐰 ' + (pet.pet_type || 'Khác') %>
                                </span>
                                <% if (pet.status !== 'available') { %>
                                    <span class="card-tag card-tag-adopted">🏠 Đã nhận nuôi</span>
                                <% } %>

                                <h3 class="card-title"><%= pet.name %></h3>

                                <% if (pet.pet_code) { %>
                                    <p style="font-size: 0.8rem; color: #2d6a4f; margin-bottom: 8px;">Mã: <%= pet.pet_code %></p>
                                <% } %>

                                <p class="card-text">
                                    <%= pet.description ? pet.description.substring(0, 130) + (pet.description.length > 130 ? '...' : '') : '' %>
                                </p>

                                <div class="pet-info">
                                    <% if (pet.breed) { %><span>🐾 <%= pet.breed %></span><% } %>
                                    <% if (pet.age) { %><span>🎂 <%= pet.age %></span><% } %>
                                    <% if (pet.gender) { %>
                                        <span><%= pet.gender==='Đực' ? '♂️' : '♀️' %> <%= pet.gender %></span>
                                    <% } %>
                                </div>

                                <div class="card-meta">
                                    <span class="liked-at">
                                        <% if (pet.liked_at) { %>
                                            ❤️ Đã thích <%= new Date(pet.liked_at).toLocaleDateString('vi-VN') %>
                                        <% } %>
                                    </span>
                                    <div style="display: flex; gap: 10px; align-items: center;">
                                        <button class="btn-unlike" title="Bỏ yêu thích"
                                            onclick="removeFavorite(<%= pet.id %>, this)">🤍</button>
                                        <a href="/adopt/<%= pet.id %>" class="btn-green">Xem chi tiết</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon">💔</div>
                    <h3>Bạn chưa có thú cưng yêu thích nào</h3>
                    <p>Hãy khám phá các bé thú cưng đang chờ được nhận nuôi và bấm ❤️ để lưu lại nhé!</p>
                    <a href="/adopt" class="btn-green" style="padding: 14px 32px; font-size: 1rem;">
                        🐾 Khám phá thú cưng
                    </a>
                </div>
            <% } %>
        </div>
    </section>

    <%- include('partials/footer') %>

    <script>
        async function removeFavorite(petId, btnEl) {
            const card = document.getElementById('favCard-' + petId);

            // Optimistic: fade the card
            if (card) card.style.opacity = '0.4';
            btnEl.disabled = true;

            try {
                const response = await fetch('/adopt/' + petId + '/like', { method: 'DELETE' });
                const data = await response.json();

                if (!response.ok) throw new Error(data.message || 'Lỗi');

                if (typeof refreshFavoritesOverlay === 'function') {
                    refreshFavoritesOverlay();
                }

                // Remove card with animation
                if (card) {
                    card.style.transition = 'all 0.4s ease';
                    card.style.transform = 'scale(0.9)';
                    card.style.opacity = '0';
                    setTimeout(() => {
                        card.remove();

                        // Check if grid is now empty
                        const grid = document.getElementById('favoritesGrid');
                        if (grid && grid.children.length === 0) {
                            location.reload();
                        }

                        // Update counter
                        const countEl = document.querySelector('.favorites-count');
                        if (countEl && grid) {
                            countEl.textContent = grid.children.length + ' thú cưng yêu thích';
                        }
                    }, 400);
                }

                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Đã bỏ yêu thích',
                    showConfirmButton: false,
                    timer: 1500
                });
            } catch (error) {
                // Rollback
                if (card) card.style.opacity = '1';
                btnEl.disabled = false;

                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'error',
                    title: error.message || 'Không thể thực hiện',
                    showConfirmButton: false,
                    timer: 2000
                });
            }
        }
    </script>
</body>

</html>
