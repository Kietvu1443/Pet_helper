<!-- ============ FOUND PET OVERLAY ============ -->
<div id="found-overlay" class="report-overlay">
    <div class="report-overlay-backdrop" onclick="closeOverlay('found-overlay')"></div>
    <div class="report-overlay-modal">
        <!-- Close Button -->
        <button type="button" class="report-overlay-close" onclick="closeOverlay('found-overlay')" aria-label="Đóng">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"
                stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>

        <form id="found-report-form" action="/reports" method="POST" enctype="multipart/form-data">

            <input type="hidden" name="type" value="found">

            <!-- Header -->
            <div class="report-form-header report-form-header--found">
                <div class="report-form-header__left">
                    <span class="report-found-badge">🏠</span>
                    <h2 class="report-form-header__title">Báo tin đã tìm thấy bé</h2>
                </div>
            </div>

            <!-- Body Form -->
            <div class="report-form-body">
                <h3 class="report-form-section-title report-form-section-title--found">
                    Thông tin dành cho chủ nhân
                </h3>
                <p class="report-form-section-subtitle">Vui lòng cung cấp chi tiết để chủ nhân có thể nhận diện và liên
                    hệ.</p>

                <!-- Đặc điểm thú cưng -->
                <div class="report-form-highlight-box">
                    <div class="report-form-grid">
                        <div class="report-form-field">
                            <label class="report-form-label">Loài thú cưng</label>
                            <div class="report-radio-group">
                                <label class="report-radio-label">
                                    <input type="radio" name="species" value="dog" checked> Chó
                                </label>
                                <label class="report-radio-label">
                                    <input type="radio" name="species" value="cat"> Mèo
                                </label>
                                <label class="report-radio-label">
                                    <input type="radio" name="species" value="other"> Khác
                                </label>
                            </div>
                        </div>
                        <div class="report-form-field">
                            <label class="report-form-label">Giới tính</label>
                            <select name="gender" class="report-form-input">
                                <option value="unknown">Không rõ</option>
                                <option value="male">Đực</option>
                                <option value="female">Cái</option>
                            </select>
                        </div>
                        <div class="report-form-field report-form-field--full">
                            <label class="report-form-label">Màu lông chủ đạo</label>
                            <input type="text" name="furColor" class="report-form-input"
                                placeholder="Ví dụ: Vàng trắng, đen tuyền, tam thể...">
                        </div>
                    </div>
                </div>

                <!-- Vị trí -->
                <div class="report-form-field">
                    <label class="report-form-label">📍 Vị trí phát hiện bé <span
                            class="report-required">*</span></label>
                    <input type="text" name="location" required class="report-form-input"
                        placeholder="Bạn nhặt được bé ở đâu? (Số nhà, tên đường, quận/huyện...)">
                </div>

                <!-- Mô tả -->
                <div class="report-form-field">
                    <label class="report-form-label">📋 Mô tả tình trạng chi tiết</label>
                    <textarea name="description" rows="3" class="report-form-input report-form-textarea"
                        placeholder="Bé có đeo vòng cổ không? Tình trạng sức khỏe hiện tại? Các đặc điểm dị biệt khác..."></textarea>
                </div>

                <!-- Thông tin liên lạc -->
                <div class="report-form-grid">
                    <div class="report-form-field">
                        <label class="report-form-label">Tên người tìm thấy <span
                                class="report-required">*</span></label>
                        <input type="text" name="finderName" required class="report-form-input"
                            placeholder="Tên của bạn">
                    </div>
                    <div class="report-form-field">
                        <label class="report-form-label">SĐT liên hệ <span class="report-required">*</span></label>
                        <input type="tel" name="phone" required class="report-form-input"
                            placeholder="Số điện thoại của bạn">
                    </div>
                </div>

                <!-- Email -->
                <div class="report-form-field">
                    <label class="report-form-label">Email liên hệ (tùy chọn)</label>
                    <input type="email" name="email" class="report-form-input"
                        placeholder="Địa chỉ email để nhận thông báo tự động">
                </div>

                <!-- Upload ảnh -->
                <div class="report-form-field">
                    <label class="report-form-label">Hình ảnh thực tế lúc tìm thấy</label>
                    <div class="report-file-upload report-file-upload--dropzone">
                        <label class="report-dropzone-label">
                            <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                                xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                            </svg>
                            <p><strong>Bấm để tải ảnh</strong> hoặc kéo thả vào đây</p>
                            <input type="file" name="images" class="report-file-hidden" accept="image/*" multiple
                                onchange="const count = this.files.length; this.closest('.report-file-upload').querySelector('.report-file-name').textContent = count > 1 ? count + ' ảnh đã được chọn' : (count === 1 ? this.files[0].name : 'Chưa có file nào được chọn')" />
                        </label>
                        <span class="report-file-name">Chưa có file nào được chọn</span>
                    </div>
                </div>
            </div>

            <!-- Footer / Submit -->
            <div class="report-form-footer">
                <button type="submit" class="report-submit-btn report-submit-btn--found">
                    Gửi thông báo tới chủ nhân
                </button>
            </div>
        </form>
    </div>
</div>