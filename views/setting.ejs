<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Dùng Phosphor Icons cho đẹp -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* CSS Thuần - Khai báo biến cho Light/Dark mode */
        :root {
            --bg-body: #F4F7F6;
            --bg-surface: #FFFFFF;
            --text-main: #1A202C;
            --text-muted: #718096;
            --border-color: #E2E8F0;
            --hover-bg: #EDF2F7;
            --primary: #2b663e;
            --blue-light: #e6f0eb;
            --accent: #F59E0B;
            --navbar-bg: #2b663e;
            --navbar-text: #FFFFFF;
        }

        [data-theme="dark"] {
            --bg-body: #121614;
            --bg-surface: #1E2421;
            --text-main: #E2E8F0;
            --text-muted: #A0AEC0;
            --border-color: #2D3748;
            --hover-bg: #2D3748;
            --primary: #4ade80;
            --blue-light: rgba(74, 222, 128, 0.15);
            --navbar-bg: #111c16;
            --navbar-text: #E2E8F0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            transition: background-color 0.3s, color 0.3s;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Navbar & Header */
        .navbar {
            height: 64px;
            background-color: var(--navbar-bg);
            color: var(--navbar-text);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            z-index: 50;
        }

        .sub-navbar {
            background-color: var(--navbar-bg);
            color: var(--navbar-text);
            display: flex;
            justify-content: center;
            gap: 40px;
            padding: 12px 0;
            font-size: 14px;
            font-weight: 700;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            text-transform: uppercase;
        }

        .sub-navbar div {
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .sub-navbar div:hover {
            opacity: 0.8;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 32px;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 24px;
            font-size: 14px;
            font-weight: 600;
        }

        .logo-btn {
            background-color: white;
            color: var(--navbar-bg);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
        }

        .logo-text {
            font-weight: 800;
            font-size: 20px;
            letter-spacing: 0.5px;
        }

        .nav-search-bar {
            background-color: rgba(255, 255, 255, 0.15);
            border-radius: 50px;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            width: 300px;
        }

        .nav-search-bar input {
            background: transparent;
            border: none;
            outline: none;
            color: white;
            width: 100%;
            font-size: 14px;
        }

        .nav-search-bar input::placeholder {
            color: rgba(255, 255, 255, 0.7);
        }

        .cart-badge {
            background-color: var(--accent);
            color: #000;
            padding: 2px 8px;
            border-radius: 12px;
            font-weight: bold;
            font-size: 12px;
            margin-left: 4px;
        }

        .search-bar {
            background-color: var(--bg-body);
            border-radius: 50px;
            padding: 8px 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            width: 240px;
        }

        .search-bar input {
            background: transparent;
            border: none;
            outline: none;
            color: var(--text-main);
            width: 100%;
        }

        .nav-icon {
            width: 40px;
            height: 40px;
            background-color: var(--hover-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            cursor: pointer;
            color: var(--text-main);
        }

        .nav-tab {
            width: 110px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            cursor: pointer;
            color: var(--text-muted);
            border-radius: 8px;
        }

        .nav-tab.active {
            color: var(--primary);
            border-bottom: 3px solid var(--primary);
            border-radius: 0;
        }

        .nav-tab:not(.active):hover {
            background-color: var(--hover-bg);
        }

        /* Main Layout */
        .layout {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: 360px;
            background-color: var(--bg-surface);
            border-right: 1px solid var(--border-color);
            padding: 16px;
            overflow-y: auto;
        }

        .sidebar h1 {
            font-size: 24px;
            margin-bottom: 16px;
        }

        .meta-card {
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 16px;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .meta-card:hover {
            background-color: var(--hover-bg);
        }

        .meta-card .brand {
            color: var(--primary);
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
        }

        .meta-card ul {
            list-style: none;
            margin-top: 12px;
            color: var(--text-main);
            font-size: 14px;
        }

        .meta-card li {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
        }

        .menu-section {
            margin-top: 24px;
        }

        .menu-section h3 {
            font-size: 17px;
            margin-bottom: 4px;
        }

        .menu-section p {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 12px;
            line-height: 1.4;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            font-size: 15px;
        }

        .menu-item:hover {
            background-color: var(--hover-bg);
        }

        .menu-item i {
            font-size: 20px;
            color: var(--text-muted);
        }

        /* Content Area */
        .content {
            flex: 1;
            padding: 32px;
            overflow-y: auto;
        }

        .content-inner {
            max-width: 800px;
            margin: 0 auto;
        }

        .card {
            background-color: var(--bg-surface);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        }

        .grid-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .feature-card {
            background-color: var(--bg-surface);
            border-radius: 12px;
            padding: 20px;
            cursor: pointer;
            border: 1px solid transparent;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        }

        .feature-card:hover {
            border-color: var(--border-color);
            background-color: var(--hover-bg);
        }

        .feature-icon {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background-color: var(--hover-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-bottom: 16px;
        }

        .feature-card h3 {
            font-size: 17px;
            margin-bottom: 4px;
        }

        .feature-card p {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.4;
        }

        .action-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .action-card {
            background-color: var(--bg-surface);
            border-radius: 12px;
            padding: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            border: 1px solid transparent;
        }

        .action-card:hover {
            border-color: var(--border-color);
            background-color: var(--hover-bg);
        }

        .action-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .action-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background-color: var(--hover-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        /* --- Style cho phần Hồ sơ Form --- */
        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background-color: var(--bg-body);
            color: var(--text-main);
            outline: none;
            transition: all 0.2s;
            font-size: 15px;
        }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--blue-light);
        }

        .btn {
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: opacity 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
        }

        .btn-primary {
            background-color: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            opacity: 0.9;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--primary);
            color: var(--primary);
        }

        .btn-outline:hover {
            background-color: var(--blue-light);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .alert {
            padding: 16px;
            border-radius: 12px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 24px;
            line-height: 1.5;
        }

        .alert-warning {
            background-color: rgba(245, 158, 11, 0.1);
            border: 1px solid rgba(245, 158, 11, 0.3);
            color: #B45309;
        }

        [data-theme="dark"] .alert-warning {
            color: #FDE68A;
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 24px;
            margin-bottom: 24px;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background-color: var(--hover-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            border: 2px solid var(--border-color);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: bold;
            margin-top: 8px;
        }

        .status-unverified {
            background-color: rgba(239, 68, 68, 0.1);
            color: #DC2626;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        [data-theme="dark"] .status-unverified {
            color: #FCA5A5;
        }

        .status-verified {
            background-color: rgba(34, 197, 94, 0.1);
            color: #16A34A;
            border: 1px solid rgba(34, 197, 94, 0.2);
        }

        [data-theme="dark"] .status-verified {
            color: #86EFAC;
        }

        .btn-verify {
            background-color: #DC2626;
            color: white;
            font-size: 13px;
            padding: 8px 16px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 8px;
            transition: all 0.2s;
        }

        .btn-verify:hover {
            background-color: #B91C1C;
        }

        .btn-verify:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="nav-left">
            <a href="/" style="display: flex; align-items: center; gap: 8px; cursor: pointer; text-decoration: none; color: inherit;">
                <div class="logo-btn">PET</div>
                <div class="logo-text">PET HELPER</div>
            </a>
            <div class="nav-search-bar">
                <i class="ph ph-magnifying-glass" style="color: rgba(255,255,255,0.7); font-size: 18px;"></i>
                <input type="text" placeholder="Tìm thú cưng, bài viết...">
            </div>
        </div>
        <div class="nav-right">
            <div style="cursor: pointer; display: flex; align-items: center; gap: 4px;"><%= user.display_name %> <i
                    class="ph-fill ph-caret-down" style="font-size: 12px;"></i></div>
            <div style="cursor: pointer; display: flex; align-items: center;">Giỏ hàng <span class="cart-badge">0</span>
            </div>
            <div style="cursor: pointer;">VN / EN</div>
        </div>
    </nav>
    <div class="sub-navbar">
        <a href="/adopt" style="display: flex; align-items: center; gap: 4px; color: inherit; text-decoration: none;">NHẬN NUÔI <i class="ph-fill ph-caret-down"
                style="font-size: 12px;"></i></a>
        <div style="display: flex; align-items: center; gap: 4px;">THẤT LẠC <i class="ph-fill ph-caret-down"
                style="font-size: 12px;"></i></div>
        <div style="display: flex; align-items: center; gap: 4px;">DỊCH VỤ <i class="ph-fill ph-caret-down"
                style="font-size: 12px;"></i></div>
        <div>TIN TỨC</div>
        <div style="display: flex; align-items: center; gap: 4px;">VỀ CHÚNG TÔI <i class="ph-fill ph-caret-down"
                style="font-size: 12px;"></i></div>
    </div>

    <!-- Main Layout -->
    <div class="layout">
        <!-- Sidebar -->
        <aside class="sidebar">
            <h1
                style="font-size: 22px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border-color);">
                Cài đặt</h1>

            <div class="menu-section" style="margin-top: 0;">
                <h3
                    style="color: var(--primary); text-transform: uppercase; font-size: 12px; letter-spacing: 1px; margin-bottom: 12px;">
                    Tài khoản</h3>

                <!-- Thêm class active hoặc custom style cho mục đang được chọn -->
                <div class="menu-item" style="background-color: var(--blue-light); color: var(--primary);">
                    <i class="ph-fill ph-user-circle" style="color: var(--primary);"></i>
                    <span style="font-weight: 600;">Hồ sơ <%= user.display_name %></span>
                </div>

                <div class="menu-item">
                    <i class="ph ph-shield-check"></i>
                    <span>Bảo mật & Mật khẩu</span>
                </div>
                <div class="menu-item">
                    <i class="ph ph-users"></i>
                    <span>Gia đình</span>
                </div>
            </div>

            <div class="menu-section" style="margin-top: 32px;">
                <h3
                    style="color: var(--primary); text-transform: uppercase; font-size: 12px; letter-spacing: 1px; margin-bottom: 12px;">
                    Tùy chọn</h3>

                
                <div class="menu-item">
                    <i class="ph ph-palette"></i>
                    <span>Giao diện hiển thị</span>
                </div>
                <div class="menu-item">
                    <i class="ph ph-globe"></i>
                    <span>Ngôn ngữ (VN)</span>
                </div>
                <% if(user && (user.role === 0 || user.role === 1)) { %>
                    <a class="menu-item" href="/admin/adoption-requests" style="text-decoration: none; color: inherit;">
                        <i class="ph ph-clipboard-text"></i>
                        <span>Xét duyệt thú cưng</span>
                    </a>
                <% } %>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="content">
            <div class="content-inner">

                <h2 style="font-size: 24px; margin-bottom: 24px;">Hồ sơ nhận nuôi</h2>

                <!-- Banner cảnh báo chưa xác thực -->
                <% if (user.verify !== 1) { %>
                <div class="alert alert-warning">
                    <i class="ph-fill ph-warning-circle"
                        style="font-size: 28px; flex-shrink: 0; color: var(--accent);"></i>
                    <div>
                        <h4 style="font-size: 16px; margin-bottom: 4px;">Tài khoản chưa đủ điều kiện nhận nuôi</h4>
                        <p style="font-size: 14px; opacity: 0.9;">Để đảm bảo an toàn và tìm được mái ấm tốt nhất cho các
                            bé thú cưng, bạn cần cập nhật đầy đủ thông tin cá nhân và <b> xác thực tài khoản thông qua
                                OTP</b> trước
                            khi gửi yêu cầu nhận nuôi. <a href="#"
                                style="color: inherit; font-weight: bold; text-decoration: underline;">Tìm hiểu thêm quy
                                trình</a></p>
                    </div>
                </div>
                <% } %>

                <div class="card">
                    <div class="profile-header">
                        <div class="profile-avatar">👤</div>
                        <div>
                            <h3 style="font-size: 20px; margin-bottom: 4px;"><%= user.name %></h3>
                            <% if (user.verify === 1) { %>
                                <div class="status-badge status-verified">
                                    <i class="ph-bold ph-check"></i> Đã xác thực
                                </div>
                            <% } else { %>
                                <div class="status-badge status-unverified">
                                    <i class="ph-bold ph-x"></i> Chưa xác thực
                                </div>
                                <br>
                                <button class="btn-verify" id="sendOtpBtn" onclick="handleSendOtp()">
                                    <i class="ph ph-envelope-simple"></i> Xác minh email
                                </button>
                            <% } %>
                        </div>
                        <div style="margin-left: auto;">
                            <button class="btn btn-outline"><i class="ph ph-upload-simple"></i> Đổi ảnh đại
                                diện</button>
                        </div>
                    </div>

                    <hr style="border: none; border-top: 1px solid var(--border-color); margin: 24px 0;">

                    <h3 style="font-size: 18px; margin-bottom: 20px;">Thông tin cá nhân</h3>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="form-group">
                            <label class="form-label">Họ và tên đầy đủ <span style="color: #DC2626;">*</span></label>
                            <input type="text" class="form-control" value="<%= user.name %>" placeholder="Ví dụ: Nguyễn Văn A">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Ngày tháng năm sinh <span style="color: #DC2626;">*</span></label>
                            <input type="date" class="form-control" value="<%= user.birthday ? new Date(user.birthday).toISOString().split('T')[0] : '' %>">
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="form-group">
                            <label class="form-label">Số điện thoại liên hệ <span
                                    style="color: #DC2626;">*</span></label>
                            <input type="tel" class="form-control" placeholder="09xx xxx xxx">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" value="<%= user.email %>" readonly
                                style="opacity: 0.7; cursor: not-allowed;">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Địa chỉ nơi bạn sẽ nuôi pet <span
                                style="color: #DC2626;">*</span></label>
                        <input type="text" class="form-control" value="<%= user.address || '' %>"
                            placeholder="Ví dụ: Khu Đô Thị Mỹ Phước, Phường Thới Hòa, Bến Cát, Bình Dương">
                    </div>

                    <div class="form-group"
                        style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 12px;">
                        <button class="btn btn-outline">Hủy thay đổi</button>
                        <button class="btn btn-primary"><i class="ph ph-floppy-disk"></i> Lưu thay đổi</button>
                    </div>
                </div>

                <div style="height: 40px;"></div>
            </div>
        </main>
    </div>

    <!-- Script xử lý Dark Mode (Client-side)
    <script>
        // Kiểm tra xem máy người dùng đang dùng dark mode không để set mặc định
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script> -->

    <!-- Script xử lý OTP -->
    <script>
        let cooldownTimer = null;
        let cooldownSeconds = 0;

        // Gửi OTP
        async function handleSendOtp() {
            const btn = document.getElementById('sendOtpBtn');
            if (!btn || btn.disabled) return;

            btn.disabled = true;
            btn.innerHTML = '<i class="ph ph-spinner"></i> Đang gửi...';

            try {
                const res = await fetch('/auth/send-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                });
                const data = await res.json();

                if (!res.ok) {
                    // Nếu server trả waitSeconds (cooldown), bắt đầu đếm ngược
                    if (data.waitSeconds) {
                        startCooldown(data.waitSeconds);
                    } else {
                        btn.disabled = false;
                        btn.innerHTML = '<i class="ph ph-envelope-simple"></i> Xác minh email';
                    }
                    Swal.fire({
                        icon: 'warning',
                        title: 'Không thể gửi OTP',
                        text: data.error,
                        confirmButtonColor: '#2b663e',
                    });
                    return;
                }

                // Gửi thành công → bắt đầu cooldown 60s
                startCooldown(60);

                // Mở popup nhập OTP
                showOtpInput();

            } catch (err) {
                console.error(err);
                btn.disabled = false;
                btn.innerHTML = '<i class="ph ph-envelope-simple"></i> Xác minh email';
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Đã xảy ra lỗi khi gửi OTP.',
                    confirmButtonColor: '#2b663e',
                });
            }
        }

        // Bắt đầu đếm ngược cooldown trên nút
        function startCooldown(seconds) {
            const btn = document.getElementById('sendOtpBtn');
            if (!btn) return;

            cooldownSeconds = seconds;
            btn.disabled = true;

            if (cooldownTimer) clearInterval(cooldownTimer);

            updateCooldownText();
            cooldownTimer = setInterval(() => {
                cooldownSeconds--;
                if (cooldownSeconds <= 0) {
                    clearInterval(cooldownTimer);
                    cooldownTimer = null;
                    btn.disabled = false;
                    btn.innerHTML = '<i class="ph ph-envelope-simple"></i> Xác minh email';
                } else {
                    updateCooldownText();
                }
            }, 1000);
        }

        function updateCooldownText() {
            const btn = document.getElementById('sendOtpBtn');
            if (btn) {
                btn.innerHTML = `<i class="ph ph-clock"></i> Gửi lại sau ${cooldownSeconds}s`;
            }
        }

        // Hiển thị SweetAlert nhập OTP
        function showOtpInput() {
            Swal.fire({
                title: '🔐 Nhập mã OTP',
                html: `
                    <p style="margin-bottom: 16px; color: #666;">Chúng tôi đã gửi mã gồm 6 chữ số đến email của bạn.</p>
                    <input type="text" id="otpInput" class="swal2-input" maxlength="6" placeholder="Nhập mã OTP"
                        style="text-align: center; font-size: 24px; letter-spacing: 8px; font-weight: 700;">
                `,
                showCancelButton: true,
                confirmButtonText: 'Xác nhận',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#2b663e',
                cancelButtonColor: '#64748B',
                focusConfirm: false,
                preConfirm: () => {
                    const otp = document.getElementById('otpInput').value.trim();
                    if (!otp || otp.length !== 6) {
                        Swal.showValidationMessage('Vui lòng nhập đúng mã OTP 6 chữ số');
                        return false;
                    }
                    return otp;
                },
            }).then(async (result) => {
                if (result.isConfirmed && result.value) {
                    await verifyOtp(result.value);
                }
            });
        }

        // Xác thực OTP
        async function verifyOtp(otp) {
            try {
                Swal.fire({
                    title: 'Đang xác thực...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading(),
                });

                const res = await fetch('/auth/verify-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otp }),
                });
                const data = await res.json();

                if (!res.ok) {
                    await Swal.fire({
                        icon: 'error',
                        title: 'Xác thực thất bại',
                        text: data.error,
                        confirmButtonColor: '#2b663e',
                        showCancelButton: true,
                        cancelButtonText: 'Đóng',
                        confirmButtonText: 'Thử lại',
                    }).then((result) => {
                        if (result.isConfirmed) {
                            showOtpInput();
                        }
                    });
                    return;
                }

                // Xác thực thành công!
                await Swal.fire({
                    icon: 'success',
                    title: 'Thành công! 🎉',
                    text: data.message,
                    confirmButtonColor: '#2b663e',
                });

                // Reload trang để cập nhật UI
                window.location.reload();

            } catch (err) {
                console.error(err);
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Đã xảy ra lỗi khi xác thực.',
                    confirmButtonColor: '#2b663e',
                });
            }
        }
    </script>
</body>

</html>
