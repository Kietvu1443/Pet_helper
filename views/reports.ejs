<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Tin Tìm Bé Lạc</title>
    <!-- Nhúng Tailwind CSS qua CDN để xem trước dễ dàng -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        /* Tùy chỉnh thanh cuộn cho textarea gọn hơn */
        textarea::-webkit-scrollbar {
            width: 8px;
        }

        textarea::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }

        textarea::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 4px;
        }
    </style>
</head>

<body class="bg-gray-100 min-h-screen flex items-center justify-center p-4">

    <!-- Form Container -->
    <!-- Action trỏ về route xử lý của Express (ví dụ: /api/posts), thêm enctype để up ảnh -->
    <form action="/reports" method="POST" enctype="multipart/form-data"
        class="bg-white w-full max-w-5xl rounded-2xl shadow-2xl overflow-hidden transition-all">

        <input type="hidden" name="type" value="lost">

        <!-- Header -->
        <div class="bg-[#2a6b47] px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <span class="bg-[#ff4757] text-white text-xs font-bold px-2.5 py-1 rounded shadow-sm tracking-wider">
                    SOS
                </span>
                <h1 class="text-white font-bold text-lg sm:text-xl uppercase tracking-wide">
                    Đăng tin tìm bé lạc
                </h1>
            </div>
            <!-- Nút Close (có thể dùng JS để đóng modal) -->
            <a href="/"><button type="button"
                    class="text-white/80 hover:text-white hover:bg-white/20 rounded-full p-1.5 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
        </div>

        <!-- Body Form -->
        <div class="p-6 sm:p-8 bg-[#f8fafc]">
            <h2 class="text-[#e11d48] font-bold text-xl mb-6 pb-3 border-b border-gray-200 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Thông tin bé bị thất lạc
            </h2>

            <div class="space-y-6">
                <!-- Group 1: Thông tin cơ bản của bé -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Loại thú -->
                    <div>
                        <label for="type" class="block text-sm font-semibold text-gray-700 mb-2">
                            Loài <span class="text-red-500">*</span>
                        </label>
                        <select id="type" name="pet_type" required
                            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow bg-white text-gray-700">
                            <option value="dog" <%=locals.oldData && oldData.pet_type==='dog' ? 'selected' : '' %>>Chó
                            </option>
                            <option value="cat" <%=locals.oldData && oldData.pet_type==='cat' ? 'selected' : '' %>>Mèo
                            </option>
                            <option value="other" <%=locals.oldData && oldData.pet_type==='other' ? 'selected' : '' %>
                                >Khác
                            </option>
                        </select>
                    </div>

                    <!-- Giới tính -->
                    <div>
                        <label for="gender" class="block text-sm font-semibold text-gray-700 mb-2">
                            Giới tính <span class="text-red-500">*</span>
                        </label>
                        <select id="gender" name="gender" required
                            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow bg-white text-gray-700">
                            <option value="unknown" <%=locals.oldData && oldData.gender==='unknown' ? 'selected' : '' %>
                                >
                                Chưa rõ</option>
                            <option value="male" <%=locals.oldData && oldData.gender==='male' ? 'selected' : '' %>>Đực
                            </option>
                            <option value="female" <%=locals.oldData && oldData.gender==='female' ? 'selected' : '' %>>
                                Cái</option>
                        </select>
                    </div>

                    <!-- Tên bé -->
                    <div>
                        <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">
                            Tên gọi của bé <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="name" name="name" required
                            value="<%= locals.oldData ? oldData.name : '' %>"
                            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow bg-white placeholder-gray-400"
                            placeholder="Ví dụ: Bé Lu, Mi Mi...">
                    </div>

                    <!-- Giống -->
                    <div>
                        <label for="species" class="block text-sm font-semibold text-gray-700 mb-2">
                            Giống (Species) <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="species" name="species" required
                            value="<%= locals.oldData ? oldData.species : '' %>"
                            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow bg-white placeholder-gray-400"
                            placeholder="Ví dụ: Poodle, Mèo mướp...">
                    </div>

                    <!-- Màu sắc -->
                    <div class="md:col-span-2">
                        <label for="color" class="block text-sm font-semibold text-gray-700 mb-2">
                            Màu sắc <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="color" name="color" required
                            value="<%= locals.oldData ? oldData.color : '' %>"
                            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow bg-white placeholder-gray-400"
                            placeholder="Ví dụ: Nâu đỏ, Vàng trắng, Đen tuyền...">
                    </div>
                </div>

                <!-- Group 1.5: Đặc điểm (Full width) -->
                <div>
                    <label for="description" class="block text-sm font-semibold text-gray-700 mb-2">
                        Đặc điểm nhận dạng chi tiết / Ghi chú thêm
                    </label>
                    <textarea id="description" name="description" rows="3"
                        class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow resize-none bg-white placeholder-gray-400"
                        placeholder="Ví dụ: Bé có đeo vòng cổ màu xanh, đuôi cụt, nhát người..."><%= locals.oldData ? oldData.description : '' %></textarea>
                </div>

                <!-- Group 2: Vị trí (Full width) -->
                <div>
                    <label for="location"
                        class="block text-sm font-semibold text-gray-700 mb-2 flex items-center gap-1">
                        <span class="text-red-500">📍</span> Vị trí cuối cùng nhìn thấy bé <span
                            class="text-red-500">*</span>
                    </label>
                    <input type="text" id="location" name="location" required
                        value="<%= locals.oldData ? oldData.location : '' %>"
                        class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow bg-white placeholder-gray-400"
                        placeholder="Ví dụ: Số nhà, tên đường, khu vực...">
                </div>

                <!-- Group 3: Thông tin liên lạc -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <!-- Số điện thoại -->
                    <div>
                        <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">
                            Số điện thoại liên lạc <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-500">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20"
                                    fill="currentColor">
                                    <path
                                        d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
                                </svg>
                            </span>
                            <input type="tel" id="phone" name="phone" required
                                value="<%= locals.user ? user.phone : '' %>"
                                class="w-full pl-11 pr-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow bg-white placeholder-gray-400"
                                placeholder="090x xxx xxx">
                        </div>
                    </div>

                    <!-- Email -->
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
                            Email liên hệ
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-500">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20"
                                    fill="currentColor">
                                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                                </svg>
                            </span>
                            <input type="email" id="email" name="email" value="<%= locals.user ? user.email : '' %>"
                                class="w-full pl-11 pr-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#2a6b47] focus:border-[#2a6b47] outline-none transition-shadow bg-white placeholder-gray-400"
                                placeholder="nguyenvana@email.com">
                        </div>
                    </div>
                </div>

                <!-- Group 4: Upload ảnh -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Tải ảnh bé lên (giúp tìm nhanh hơn)
                    </label>
                    <div class="flex items-center gap-4">
                        <!-- Custom File Input Button -->
                        <label
                            class="cursor-pointer bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 font-medium py-3 px-4 rounded-xl transition-colors flex items-center gap-2 shadow-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                            </svg>
                            <span>Chọn ảnh...</span>
                            <input type="file" name="images" class="hidden" accept="image/*" multiple
                                onchange="const count = this.files.length; document.getElementById('fileName').textContent = count > 1 ? count + ' ảnh đã được chọn' : (count === 1 ? this.files[0].name : 'Chưa có file nào được chọn')">
                        </label>
                        <span id="fileName" class="text-sm text-gray-500 italic truncate max-w-[150px] sm:max-w-xs">
                            Chưa có file nào được chọn
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer / Nút Submit -->
        <div class="bg-white px-6 py-5 border-t border-gray-100 flex justify-end">
            <button type="submit"
                class="w-full sm:w-auto bg-[#e11d48] hover:bg-[#be123c] text-white font-bold py-3 px-8 rounded-xl shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5 tracking-wide text-lg flex justify-center items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                </svg>
                ĐĂNG TIN TÌM KIẾM
            </button>
        </div>
    </form>

</body>

</html>