<!-- ============ LOST PET OVERLAY ============ -->
<div id="lost-overlay" class="report-overlay">
    <div class="report-overlay-backdrop" onclick="closeOverlay('lost-overlay')"></div>
    <div class="report-overlay-modal">
        <!-- Close Button -->
        <button type="button" class="report-overlay-close" onclick="closeOverlay('lost-overlay')" aria-label="Đóng">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>

        <form id="lost-report-form" action="/reports" method="POST" enctype="multipart/form-data">

            <input type="hidden" name="type" value="lost">

            <!-- Header -->
            <div class="report-form-header report-form-header--lost">
                <div class="report-form-header__left">
                    <span class="report-sos-badge">SOS</span>
                    <h2 class="report-form-header__title">Đăng tin tìm bé lạc</h2>
                </div>
            </div>

            <!-- Body Form -->
            <div class="report-form-body">
                <h3 class="report-form-section-title report-form-section-title--lost">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Thông tin bé bị thất lạc
                </h3>

                <div class="report-form-grid">
                    <!-- Loại thú -->
                    <div class="report-form-field">
                        <label class="report-form-label">Loài <span class="report-required">*</span></label>
                        <select name="pet_type" required class="report-form-input">
                            <option value="dog">Chó</option>
                            <option value="cat">Mèo</option>
                            <option value="other">Khác</option>
                        </select>
                    </div>

                    <!-- Giới tính -->
                    <div class="report-form-field">
                        <label class="report-form-label">Giới tính <span class="report-required">*</span></label>
                        <select name="gender" required class="report-form-input">
                            <option value="unknown">Chưa rõ</option>
                            <option value="male">Đực</option>
                            <option value="female">Cái</option>
                        </select>
                    </div>

                    <!-- Tên bé -->
                    <div class="report-form-field">
                        <label class="report-form-label">Tên gọi của bé <span class="report-required">*</span></label>
                        <input type="text" name="name" required class="report-form-input"
                            placeholder="Ví dụ: Bé Lu, Mi Mi...">
                    </div>

                    <!-- Giống -->
                    <div class="report-form-field">
                        <label class="report-form-label">Giống (Species) <span class="report-required">*</span></label>
                        <input type="text" name="species" required class="report-form-input"
                            placeholder="Ví dụ: Poodle, Mèo mướp...">
                    </div>

                    <!-- Màu sắc (full width) -->
                    <div class="report-form-field report-form-field--full">
                        <label class="report-form-label">Màu sắc <span class="report-required">*</span></label>
                        <input type="text" name="color" required class="report-form-input"
                            placeholder="Ví dụ: Nâu đỏ, Vàng trắng, Đen tuyền...">
                    </div>
                </div>

                <!-- Đặc điểm -->
                <div class="report-form-field">
                    <label class="report-form-label">Đặc điểm nhận dạng chi tiết / Ghi chú thêm</label>
                    <textarea name="description" rows="3" class="report-form-input report-form-textarea"
                        placeholder="Ví dụ: Bé có đeo vòng cổ màu xanh, đuôi cụt, nhát người..."></textarea>
                </div>

                <!-- Vị trí -->
                <div class="report-form-field">
                    <label class="report-form-label">📍 Vị trí cuối cùng nhìn thấy bé <span class="report-required">*</span></label>
                    <input type="text" name="location" required class="report-form-input"
                        placeholder="Ví dụ: Số nhà, tên đường, khu vực...">
                </div>

                <!-- Thông tin liên lạc -->
                <div class="report-form-grid">
                    <div class="report-form-field">
                        <label class="report-form-label">Số điện thoại liên lạc <span class="report-required">*</span></label>
                        <input type="tel" name="phone" required class="report-form-input"
                            value="<%= locals.user ? user.phone : '' %>"
                            placeholder="090x xxx xxx">
                    </div>
                    <div class="report-form-field">
                        <label class="report-form-label">Email liên hệ</label>
                        <input type="email" name="email" class="report-form-input"
                            value="<%= locals.user ? user.email : '' %>"
                            placeholder="nguyenvana@email.com">
                    </div>
                </div>

                <!-- Upload ảnh -->
                <div class="report-form-field">
                    <label class="report-form-label">Tải ảnh bé lên (giúp tìm nhanh hơn)</label>
                    <div class="report-file-upload">
                        <label class="report-file-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                            </svg>
                            <span>Chọn ảnh...</span>
                            <input type="file" name="images" class="report-file-hidden" accept="image/*" multiple
                                onchange="const count = this.files.length; this.closest('.report-file-upload').querySelector('.report-file-name').textContent = count > 1 ? count + ' ảnh đã được chọn' : (count === 1 ? this.files[0].name : 'Chưa có file nào được chọn')">
                        </label>
                        <span class="report-file-name">Chưa có file nào được chọn</span>
                    </div>
                </div>
            </div>

            <!-- Footer / Submit -->
            <div class="report-form-footer">
                <button type="submit" class="report-submit-btn report-submit-btn--lost">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                    </svg>
                    ĐĂNG TIN TÌM KIẾM
                </button>
            </div>
        </form>
    </div>
</div>
