<script>
/**
 * Fallback ảnh pet khi Cloudinary/remote bị lỗi (mất mạng, URL hỏng…)
 * Bước 1: Thử lấy ảnh qua API local /api/pets/{id}/local-avatar
 * Bước 2: Nếu API trả về 404 (do thư mục trống/chưa tạo) -> fallback sang ảnh mặc định
 */
function fallbackPetImage(img, id) {
    img.onerror = function () {
        img.onerror = null;
        img.src = "/images/logo.svg";
    };
    img.src = "/api/pets/" + id + "/local-avatar";
}
</script>