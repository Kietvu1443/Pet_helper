<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Pet Helper - Nền tảng hỗ trợ và bảo vệ vật nuôi hàng đầu Việt Nam">
  <title>
    <%= title %>
  </title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>Hỗ Trợ và Bảo Vệ Thú Cưng</h1>
      <p>Nền tảng kết nối cộng đồng yêu thương động vật. Nhận nuôi thú cưng, tìm kiếm thú cưng thất lạc, cảnh báo tin
        tức và nhiều hơn nữa.</p>
      <div class="hero-buttons">
        <a href="/adopt" class="btn btn-primary">🏠 Nhận nuôi ngay</a>
        <button class="btn btn-outline" id="Button_test">🔍 Báo cáo thất lạc</button>
      </div>
    </div>
  </section>

  <main class="container">
    <!-- About Section - Card Box Style -->
    <section class="card-box">
      <div class="about-header">
        <div class="section-header">
          <h2>Về Pet Helper</h2>
        </div>
        <p class="about-subtitle">
          Hành trình kết nối những tâm hồn yêu động vật và xây dựng một cộng đồng bền vững.
        </p>
      </div>

      <div class="about-content">
        <div class="about-text">
          <p class="about-text-main">
            Được thành lập tại <strong>BDU UNIS Campus</strong>, Pet Helper là hệ sinh thái toàn diện dành cho những
            người bạn bốn chân.
          </p>
          <p class="about-text-sub">
            Chúng tôi tập trung giảm thiểu số lượng thú cưng bị bỏ rơi và hỗ trợ cộng đồng tìm kiếm thú lạc nhanh chóng,
            hiệu quả nhất.
          </p>
          <p class="about-text-sub">
            Mọi hoạt động thuộc dự án <strong>Green Project</strong> đều hướng tới môi trường sống nhân văn và tràn đầy
            tình thương.
          </p>
        </div>

        <div class="about-images">
          <div class="about-images-row">
            <div class="about-img-square">
              <img src="https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?auto=format&fit=crop&w=400&q=80"
                alt="Chó 1">
            </div>
            <div class="about-img-square">
              <img src="https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&w=400&q=80"
                alt="Chó 2">
            </div>
          </div>
          <div class="about-img-wide">
            <img src="https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&w=600&q=80"
              alt="Mèo">
          </div>
        </div>
      </div>

      <!-- Feature Icons -->
      <div class="feature-icons-bar">
        <div class="feature-icon-item">
          <div class="feature-icon-emoji">🏠</div>
          <h4>Nhận Nuôi</h4>
        </div>
        <div class="feature-icon-item">
          <div class="feature-icon-emoji">🔍</div>
          <h4>Tìm Kiếm</h4>
        </div>
        <div class="feature-icon-item">
          <div class="feature-icon-emoji">🩺</div>
          <h4>Y Tế</h4>
        </div>
        <div class="feature-icon-item">
          <div class="feature-icon-emoji">🛒</div>
          <h4>Cửa Hàng</h4>
        </div>
      </div>
    </section>

    <!-- Adopt Slider Section -->
    <section>
      <div class="adopt-layout">
        <div class="adopt-slider-container">
          <div class="slide-item active">
            <img src="https://images.unsplash.com/photo-1552053831-71594a27632d?auto=format&fit=crop&w=800&q=80"
              class="ken-burns-img" alt="Slide 1">
            <div class="slider-caption-box">
              <h3>🐶 Bé Golden - Đang tìm mái ấm</h3>
              <p>3 tuổi, rất ngoan, thích chạy nhảy ngoài công viên.</p>
            </div>
          </div>
          <div class="slide-item">
            <img src="https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&w=800&q=80"
              class="ken-burns-img" alt="Slide 2">
            <div class="slider-caption-box">
              <h3>🐱 Mèo Mướp - Cần người yêu thương</h3>
              <p>Được cứu hộ từ bãi đất trống, hiện đã khỏe mạnh.</p>
            </div>
          </div>
          <div class="slide-item">
            <img src="https://images.unsplash.com/photo-1576201836106-db1758fd1c97?auto=format&fit=crop&w=800&q=80"
              class="ken-burns-img" style="animation-direction: alternate-reverse;" alt="Slide 3">
            <div class="slider-caption-box">
              <h3>🩺 Dịch vụ chăm sóc thú cưng tận tâm</h3>
              <p>Đặt lịch khám, tiêm phòng và spa cho boss.</p>
            </div>
          </div>
        </div>

        <div class="adopt-links">
          <a href="/reports" class="link-btn"><span>🔍 Bạn lạc thú cưng?</span><span>→</span></a>
          <a href="/reports/found" class="link-btn"><span>🏠 Bạn nhặt được thú cưng?</span><span>→</span></a>
          <a href="/about" class="link-btn"><span>🩺 Cách chăm sóc thú cưng?</span><span>→</span></a>
          <a href="#contact-section" class="link-btn"><span>📞 Liên hệ hỗ trợ</span><span>→</span></a>
        </div>
      </div>
      <a href="/adopt" class="adopt-label-text">Xem thêm thú có thể nhận nuôi</a>
      <div class="adopt-filter-bar">
        <a href="/adopt?type=dog"><span>🐶 Chó (12)</span></a>
        <a href="/adopt?type=cat"><span>🐱 Mèo (8)</span></a>
        <a href="/adopt" style="color: #666">Xem tất cả →</a>
      </div>
    </section>

    <!-- News Section -->
    <section class="section news-section">
      <div class="section-header">
        <h2>Tin Tức & Sự Kiện</h2>
        <p>Cập nhật những thông tin mới nhất về thế giới thú cưng</p>
      </div>

      <div class="news-grid">
        <article class="news-card">
          <img src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=400" alt="Sự kiện">
          <div class="card-body">
            <span class="news-date">📅 03/02/2026</span>
            <h3 class="card-title">Ngày hội nhận nuôi thú cưng 2026</h3>
            <p class="card-text">Sự kiện thường niên lớn nhất dành cho cộng đồng yêu thú cưng...</p>
          </div>
        </article>

        <article class="news-card">
          <img src="https://images.unsplash.com/photo-1450778869180-41d0601e046e?w=400" alt="Tin tức">
          <div class="card-body">
            <span class="news-date">📅 01/02/2026</span>
            <h3 class="card-title">Hướng dẫn chăm sóc thú cưng mùa đông</h3>
            <p class="card-text">Những lưu ý quan trọng để bảo vệ thú cưng trong thời tiết lạnh...</p>
          </div>
        </article>

        <article class="news-card">
          <img src="https://images.unsplash.com/photo-1601758228041-f3b2795255f1?w=400" alt="Tin tức">
          <div class="card-body">
            <span class="news-date">📅 28/01/2026</span>
            <h3 class="card-title">Ra mắt thẻ GPS theo dõi vật nuôi</h3>
            <p class="card-text">Công nghệ mới giúp bạn luôn biết vị trí thú cưng của mình...</p>
          </div>
        </article>
      </div>

      <div class="news-more">
        <a href="/news" class="btn btn-green">Xem thêm tin tức →</a>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="contact-section" id="contact-section">
      <div class="contact-info">
        <h2>LIÊN HỆ HỖ TRỢ</h2>
        <div class="contact-socials">
          <span class="social-icon">FB</span>
          <span class="social-icon">YT</span>
          <span class="social-icon">IG</span>
        </div>
        <div class="contact-details">
          📍 Trụ sở: BDU UNIS Campus<br>
          📧 Email: support@pethelper.vn<br>
          📞 Hotline: 1900-XXXX
        </div>
      </div>
      <div class="form-area">
        <h3 class="form-title">Gửi tin nhắn</h3>
        <input class="form-input" placeholder="Họ tên của bạn">
        <input class="form-input" placeholder="Email / SĐT">
        <textarea class="form-input" rows="3" placeholder="Lời nhắn..."></textarea>
        <button class="submit-btn" onclick="Swal.fire('Đã gửi!', 'Chúng tôi sẽ liên hệ lại sớm nhất.', 'success')">Gửi thông tin</button>
      </div>
    </section>

    <!-- Footer Bottom -->
    <div class="page-bottom-note">
      © 2026 Pet Helper Green Project.
    </div>
  </main>

  <%- include('partials/footer') %>

  <!-- JavaScript -->
  <script>
    // Slider Logic
    let currentSlide = 0;
    const slides = document.querySelectorAll('.slide-item');
    function nextSlide() {
      slides[currentSlide].classList.remove('active');
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add('active');
    }
    if (slides.length > 0) {
      setInterval(nextSlide, 5000);
    }

    // Section Animation on Scroll
    document.addEventListener("DOMContentLoaded", function () {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) entry.target.classList.add("visible");
        });
      }, { threshold: 0.15 });
      document.querySelectorAll("section").forEach(s => observer.observe(s));
    });

    // Report Lost Pet Button
    document.getElementById("Button_test").addEventListener("click", function () {
      Swal.fire({
        title: "Tính năng đang được phát triển!",
        text: "Chức năng báo cáo thất lạc sẽ sớm được ra mắt.",
        imageUrl: "/images/Lovely.jpg",
        imageWidth: 400,
        imageHeight: 200,
        imageAlt: "Custom image"
      });
    });
  </script>
</body>

</html>